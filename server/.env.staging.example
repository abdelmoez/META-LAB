# ──────────────────────────────────────────────────────────────────────────────
# server/.env.staging.example — PecanRev STAGING environment (93.md §3.3)
# Copy to the STAGING instance's server/.env and fill real values.
# NEVER commit the real file; chmod 600 it on the host.
#
# ⚠️ STAGING MUST NOT SHARE PRODUCTION ANYTHING:
#   • NOT the production database(s)   → separate DATABASE_URL / POSTGRES_* /
#     BETA_WAITLIST_DATABASE_URL (staging silently reading prod user data is a
#     data breach, and a staging migration rehearsal against prod is an outage).
#   • NOT the production JWT_SECRET    → a shared secret means a staging session
#     cookie is a VALID production session. Generate a fresh one.
#   • NOT production email delivery    → EMAIL_REDIRECT_ALL_TO below guarantees
#     staging can never email real users.
#   • NOT the production storage dir   → staging uploads stay on the staging host
#     (server/storage resolves relative to the staging checkout).
#   • NOT the production Sentry stream → SENTRY_ENVIRONMENT=staging keeps alerts
#     and dashboards separate (a distinct staging DSN/project is even better).
# See docs/manager/staging-deployment.md for the full staging pattern,
# including the migration-rehearsal flow (staging first, then production).
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime identity ───────────────────────────────────────────────────────────
# NODE_ENV=production: staging runs the full production hardening (Secure
# cookies, strict rate limits, config validation). APP_ENV=staging is what
# distinguishes it (staging banner, Sentry environment, email protection) —
# mirrors env_staging in ecosystem.config.cjs.
NODE_ENV="production"
APP_ENV="staging"
LOG_FORMAT="json"
# Staging listens on its own port; the nginx staging server block proxies
# staging.example.com → 127.0.0.1:3002 (deploy/nginx/pecanrev.conf.example).
PORT=3002

# ── Database — SEPARATE from production ────────────────────────────────────────
# SQLite (transitional): a staging-only file, never the production path.
DATABASE_URL="file:/var/lib/pecanrev-staging/staging.db"
# PostgreSQL (target): a dedicated staging database/branch on the provider
# (Neon branch / separate Supabase project) — never the production DB.
DATABASE_PROVIDER="sqlite"                  # "sqlite" | "postgres"
# POSTGRES_DATABASE_URL="postgresql://user:pass@host:5432/pecanrev_staging?schema=public"
# POSTGRES_WAITLIST_DATABASE_URL="postgresql://user:pass@host:5432/pecanrev_waitlist_staging?schema=public"

# ── Beta Waitlist DB — separate staging file/database (prompt48 isolation) ─────
BETA_WAITLIST_DATABASE_URL="file:/var/lib/pecanrev-staging/staging-waitlist.db"

# ── Auth / JWT — FRESH secret, never the production value ──────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate-a-fresh-staging-only-secret"

# ── Origin / CORS — the staging hostname, not the production one ───────────────
CORS_ORIGIN="https://staging.example.com"
APP_BASE_URL="https://staging.example.com"

# ── Admin seeding — staging-only credentials ───────────────────────────────────
ADMIN_EMAIL_1="admin@example.com"
ADMIN_EMAIL_2="ops@example.com"
ADMIN_SEED_PASSWORD="staging-only-password-change-me"

# ── Email — staging must never reach real users (93.md §3.3 / §6.1) ────────────
# Keep the normal SMTP config (so templates/links are exercised end-to-end) but
# redirect EVERY outbound message to the team inbox.
# PRECEDENCE (round 2 clarification): EMAIL_REDIRECT_ALL_TO WINS — while it is
# set, EMAIL_ALLOWLIST is ignored. Use the allowlist INSTEAD of (not alongside)
# the redirect when specific internal addresses should receive mail directly:
# set EMAIL_ALLOWLIST and leave EMAIL_REDIRECT_ALL_TO empty. Both are inert in
# production (APP_ENV/NODE_ENV=production), which logs a loud warning if they
# are set there.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="staging@example.com"
EMAIL_REDIRECT_ALL_TO="team@example.com"
# EMAIL_ALLOWLIST="qa@example.com,dev@example.com"

# ── Sentry — separate environment (ideally a separate DSN/project) ─────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT="staging"
SENTRY_TRACES_SAMPLE_RATE=0
