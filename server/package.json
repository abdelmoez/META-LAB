{
  "name": "meta-lab-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:sync-postgres-schema": "node scripts/sync-postgres-schema.mjs",
    "db:generate:postgres": "node scripts/sync-postgres-schema.mjs && prisma generate --schema=prisma/postgres/schema.prisma && prisma generate --schema=prisma/postgres/waitlist-schema.prisma",
    "db:push:postgres": "prisma db push --schema=prisma/postgres/schema.prisma && prisma db push --schema=prisma/postgres/waitlist-schema.prisma",
    "db:migrate:postgres": "node scripts/migrate-db.mjs",
    "db:verify:postgres": "node scripts/verify-migration.mjs",
    "generate:waitlist": "prisma generate --schema=prisma/waitlist/schema.prisma",
    "db:ensure:waitlist": "node scripts/ensure-waitlist-db.mjs",
    "postinstall": "node scripts/ensure-waitlist-db.mjs --with-generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "optionalDependencies": {
    "geoip-lite": "^1.4.10"
  }
}
