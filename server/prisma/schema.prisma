// META·LAB Prisma schema
// Provider: SQLite (via Prisma ORM)
// Auth: users own projects — userId enforced on every query

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String?
  password    String    // bcrypt hash — never stored or returned as plain text
  role        String    @default("user")   // "user" | "admin"
  suspended   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastActive  DateTime?
  projects    Project[]
  auditLogs   AdminAuditLog[]
}

model Project {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  data        String    @default("{}")  // JSON-serialised project payload (studies, records, pico, search, etc.)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  lastSavedAt DateTime?
}

model ContactMessage {
  id        String   @id @default(uuid())
  email     String
  name      String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String   // JSON-serialised value
  updatedAt DateTime @updatedAt
  updatedBy String?  // admin userId who last changed this
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String   // e.g. "UPDATE_SETTING", "SUSPEND_USER", "DELETE_MESSAGE"
  entityType String?  // "User", "Project", "SiteSetting", "ContactMessage", etc.
  entityId   String?
  details    String?  // JSON-serialised context (what changed, before/after summary)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model SecurityEvent {
  id        String   @id @default(uuid())
  type      String   // "FAILED_LOGIN", "ADMIN_ACCESS_DENIED", "RATE_LIMITED"
  userId    String?
  email     String?
  ip        String?
  userAgent String?
  details   String?  // JSON-serialised extra info
  createdAt DateTime @default(now())
}
