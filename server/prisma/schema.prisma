  actorId    String
  actorName  String        @default("")
  action     String // BLIND_MODE_ON | MEMBER_ADDED | RECORD_ACCEPTED | ...
  entityType String?
  entityId   String?
  details    String        @default("{}") // JSON context
  createdAt  DateTime      @default(now())
}

// ─── META·LAB RoB — Risk-of-Bias assessments (rob.md, feature flag rob_engine_v2) ─
//
// Outcome/RESULT-level: RoB 2 assesses a specific result, not a whole study, so
// each RobAssessment binds (project, study, outcome/result). All ADDITIVE and
// nullable/defaulted → `prisma db push` stays safe (no --accept-data-loss). The
// engine (src/research-engine/rob) is the single source of truth for judgements;
// these tables persist answers + BOTH the algorithm-proposed AND the final
// (possibly overridden) judgement, with a mandatory rationale on any override.
//
// studyId is the in-document study.id (8-char uid in Project.data.studies[]),
// NOT a DB FK — mirrors ReviewStudy.studyId. reviewerId is a bare user-id string
// (denormalised reviewerName) following the audit-survival precedent (ScreenAuditLog /
// UsageEvent / Notification) so records outlive the users that produced them.
// The legacy per-study `rob` field in Project.data.studies[] is left untouched;
// an adapter (server/rob/legacyAdapter.js) can surface a legacy view from it.
model RobAssessment {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studyId           String // in-document study.id (8-char uid); not a DB FK
  outcomeId         String? // optional specific outcome/result identifier
  resultLabel       String? // human-readable result being assessed (e.g. "Mortality at 6 months")
  instrumentId      String    @default("RoB2")
  instrumentVersion String    @default("2019-08-22")
  variant           String    @default("assignment") // assignment | adherence (future)
  reviewerId        String // user id (bare string; not a FK)
  reviewerName      String    @default("") // denormalised for display/audit
  status            String    @default("draft") // draft | complete | consensus
  deletedAt         DateTime? // soft delete; never hard-delete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  answers         RobAnswer[]
  domainJudgments RobDomainJudgment[]
  overall         RobOverall?

  @@index([projectId])
  @@index([projectId, studyId])
}

// One row per signalling-question answer. response ∈ Y|PY|PN|N|NI|NA. Optional
// rationale + evidence quote/locator (PDF page/offset reserved for later). The
// ai* columns reserve space for an AI-suggested answer (model + version) — never
// auto-applied. @@unique([assessmentId, questionId]) enables a clean upsert and
// is additive-safe on a brand-new table.
model RobAnswer {
  id              String        @id @default(uuid())
  assessmentId    String
  assessment      RobAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainId        String // D1..D5
  questionId      String // e.g. "2.3"
  response        String        @default("") // Y|PY|PN|N|NI|NA
  rationale       String?
  evidenceQuote   String?
  evidenceLocator String? // PDF page/offset etc. (reserved)
  aiSuggested     Boolean? // was the response AI-suggested?
  aiModel         String?
  aiModelVersion  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

// Per-domain proposed + final judgement. proposed = engine output; final =
// proposed unless overridden (overridden=true requires overrideJustification).
model RobDomainJudgment {
  id                    String        @id @default(uuid())
  assessmentId          String
  assessment            RobAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainId              String // D1..D5
  proposedJudgment      String        @default("") // low|some|high
  finalJudgment         String? // low|some|high (null until resolved)
  overridden            Boolean       @default(false)
  overrideJustification String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([assessmentId, domainId])
}

// One overall judgement per assessment (proposed + final, override-aware).
model RobOverall {
  id                    String        @id @default(uuid())
  assessmentId          String        @unique
  assessment            RobAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  proposedOverall       String        @default("") // low|some|high
  finalOverall          String?
  overridden            Boolean       @default(false)
  overrideJustification String?
  multiSomeConcernsFlag Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

// Append-only audit of every RoB create / answer / propose / override / finalise.
// No FK on purpose (audit-survival precedent): bare projectId/assessmentId strings
// so the trail outlives the assessment/project it describes.
model RobAuditLog {
  id           String   @id @default(uuid())
  projectId    String
  assessmentId String   @default("")
  actorId      String
  actorName    String   @default("")
  action       String // ROB_CREATE | ROB_ANSWER | ROB_OVERRIDE | ROB_FINALISE | ROB_DELETE
  entityType   String? // "RobAssessment" | "RobDomainJudgment" | "RobOverall"
  entityId     String?
  details      String   @default("{}") // JSON context
  createdAt    DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([assessmentId, createdAt])
}

// prompt46 #4 — RoB-local MANUAL studies. A study a permitted reviewer adds
// directly in the Risk-of-Bias module when it is NOT (yet) in the screening/
// extraction set (project.studies, which lives in the Project.data blob). These
// merge into the RoB "study universe" alongside screening-derived studies and are
// labelled source:'manual'; screening-derived studies are NOT deletable from RoB.
// Soft-deleted only (deletedAt; never hard-delete — assessments are kept). createdBy*
// are bare strings (no FK), matching the RobAuditLog / RobAssessment denormalised
// convention. Additive new table → `prisma db push` creates it cleanly.
model RobManualStudy {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String    @default("")
  authors       String    @default("") // free-text author string (mirrors studies[].author display)
  year          String    @default("") // string (studies[].year is rendered as-is)
  doi           String?
  pmid          String?
  notes         String?
  createdById   String // bare user id (not a FK) — creator
  createdByName String    @default("") // denormalised for display/audit
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([projectId])
}

// prompt38 — server-backed per-module workflow state (de-monolithization +
// concurrency-safe architecture). Replaces whole-project blob saves for MIGRATED
// modules: one row per (project, moduleKey) holding that module's stateJson with
// an optimistic-concurrency `revision`. Reads/writes are gated behind the
// `serverBackedWorkflowState` feature flag (default OFF) and authorized by the
// same META·LAB project access as the project itself (owner or linked-workspace
// member with canEdit). `updatedById` is a bare string (no FK to User), matching
// the established convention for additive collaboration tables. The composite
// `@@unique([projectId, moduleKey])` is on a NEW table, so `prisma db push`
// creates it cleanly (no --accept-data-loss).
model WorkflowModuleState {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleKey     String // whitelisted module key (see server/services/workflowState.js)
  stateJson     String   @default("{}") // the module's state, JSON-serialised
  revision      Int      @default(0) // optimistic-concurrency counter, incremented per accepted patch
  updatedById   String? // user id (bare string; not a FK)
  updatedByName String   @default("") // denormalised for display/audit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, moduleKey])
  @@index([projectId])
}

// prompt38 (limitations round) — append-only audit of workflow-module-state
// mutations + conflicts. Same no-FK audit-survival precedent as RobAuditLog: bare
// projectId/userId strings so the trail outlives the project/module it describes.
// Written best-effort (never blocks the main operation). Readable by project
// members via GET /api/workspaces/:id/audit (flag-gated).
model WorkflowStateAudit {
  id        String   @id @default(uuid())
  projectId String
  moduleKey String   @default("")
  action    String // PROTOCOL_UPDATED | …_UPDATED | WORKFLOW_STATE_CONFLICT
  revision  Int? // resulting revision (updates) / current revision (conflicts)
  userId    String?
  userName  String   @default("")
  details   String   @default("{}") // JSON: changed keys, baseRevision, etc.
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, moduleKey])
}

// ─── PecanRev Screening Intelligence Engine (flag: aiScreening) ───────
//
// AI-assisted, active-learning relevance scoring layer over META·SIFT screening.
// ALL ADDITIVE: every table below uses a BARE `projectId` scope-key string (no
// Prisma relation / FK) — the same audit-survival precedent as ScreenAuditLog /
// ScreenPdfAttachment / RobAuditLog — so adding them is a pure `prisma db push`
// with no change to any existing model and no --accept-data-loss. The AI layer
// is strictly read-only w.r.t. the human decision pipeline: it NEVER writes a
// ScreenDecision. Records are scored; humans decide.

// One row per scoring run (train + score the whole project). Stores the run's
// configuration snapshot, label counts, model summary, and an internal-validation
// snapshot (AI ranking vs human final decisions). This IS the model-run history.
model ScreenAiRun {
  id                String    @id @default(uuid())
  projectId         String // bare scope key (no FK; audit-survival)
  status            String    @default("completed") // running | completed | failed
  mode              String    @default("cold_start") // cold_start | supervised
  stage             String    @default("title_abstract")
  engineVersion     String    @default("1.0")
  trigger           String    @default("manual") // manual | auto
  // Summary
  nRecords          Int       @default(0)
  nScored           Int       @default(0)
  nFeatures         Int       @default(0)
  labelCountsJson   String    @default("{}") // {include,exclude,maybe,undecided,positives,negatives,classBalance}
  modelInfoJson     String    @default("{}") // {epochs,converged,classWeights,nPos,nNeg} or {}
  configJson        String    @default("{}") // resolved engine config snapshot (provider, weights, thresholds)
  metricsJson       String    @default("{}") // computeValidation() snapshot (auc, wss95, recall@k, stages, warning)
  failureReason     String    @default("")
  triggeredById     String? // bare user id
  triggeredByName   String    @default("") // denormalised
  // se2.md §11 — model version lifecycle, lineage + drift. A completed run is a model
  // version; exactly one per (project,stage) is the ACTIVE version whose scores are live.
  isActive          Boolean   @default(false)
  supersededAt      DateTime? // set when a newer version takes over
  parentRunId       String? // lineage: the version this one superseded
  rollbackFromRunId String? // set when this run was produced by a rollback
  snapshotHash      String    @default("") // hash of training labels + config (reproducibility)
  featureVersion    String    @default("") // feature/preprocessing version tag
  driftJson         String    @default("{}") // { snapshot, drift:{warnings,deltas,psi,collapse} }
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([projectId, stage, isActive])
}

// Latest relevance score per (project, record, stage). Upserted each run so the
// screening queue can join scores cheaply; run history lives in ScreenAiRun.
model ScreenAiScore {
  id              String   @id @default(uuid())
  projectId       String // bare scope key
  recordId        String // bare scope key (record may be soft-deleted)
  runId           String   @default("")
  stage           String   @default("title_abstract")
  score           Float    @default(0) // hybrid relevance [0,1]
  proba           Float? // supervised classifier probability, null in cold-start
  calibratedProba Float? // calibrated P(include) (se2.md §8); null when uncalibrated
  coldStartScore  Float    @default(0)
  uncertainty     Float    @default(0)
  confidence      Float    @default(0)
  prediction      String   @default("uncertain") // include | exclude | uncertain
  band            String   @default("unscored") // very_high|high|medium|low|very_low
  mode            String   @default("cold_start")
  lowConfidence   Boolean  @default(false)
  missingAbstract Boolean  @default(false)
  picoMean        Float?
  subScoresJson   String   @default("{}") // {classifier,coldStart,semantic,keyword}
  signalsJson     String   @default("{}") // {studyDesign,inclusionMatched,exclusionHits,pico}
  explanationJson String   @default("{}") // buildExplanation() output (reasons, picoBreakdown, similar, note)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, recordId, stage])
  @@index([projectId, stage])
  @@index([projectId, score])
}

// Human feedback on an AI suggestion (active-learning signal + auditability).
// Append-only; never blocks the decision flow.
model ScreenAiFeedback {
  id            String   @id @default(uuid())
  projectId     String // bare scope key
  recordId      String
  runId         String   @default("")
  aiPrediction  String   @default("") // include|exclude|uncertain at time of feedback
  aiScore       Float?
  humanDecision String   @default("") // include|exclude|maybe
  agree         Boolean? // did the human agree with the AI?
  rating        String   @default("") // helpful | not_helpful | ''
  note          String   @default("")
  givenById     String? // bare user id
  givenByName   String   @default("")
  createdAt     DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, recordId])
}

// se2.md §6/§12 — background scoring jobs. A debounced, coalesced rescore is
// queued whenever a new include/exclude decision lands, so reviewers always see
// rankings based on the latest human decisions WITHOUT a synchronous retrain in
// the decision request. One active job per (project, stage); a rerun flag picks
// up decisions that arrive mid-run. Append-only history for observability.
// Bare projectId scope key (audit-survival precedent). NEVER blocks/loses a
// human decision — the decision is saved transactionally before the job is queued.
model ScreenAiJob {
  id          String    @id @default(uuid())
  projectId   String
  stage       String    @default("title_abstract")
  kind        String    @default("rescore") // rescore | train
  status      String    @default("queued") // queued | running | completed | failed | superseded | cancelled
  trigger     String    @default("decision") // decision | manual | api
  reason      String    @default("") // failure reason (no article text)
  runId       String    @default("") // resulting ScreenAiRun id
  nScored     Int       @default(0)
  coalesced   Int       @default(0) // decisions coalesced into this job
  durationMs  Int? // observability (se2.md §17)
  // 62.md — durable, crash-recoverable background-worker fields (mirrors ScreenImportJob).
  // Manual runs now enqueue a job + return 202 instead of blocking the request thread;
  // the in-process drain worker claims + processes off the event loop. attempts caps a
  // poison-pill that keeps crashing (see server/utils/jobRetry.js); processed/total drive
  // the progress UI; heartbeatAt lets boot recovery distinguish a live run from a crash.
  attempts    Int       @default(0) // claims so far (retry-budget cap)
  processed   Int       @default(0) // records scored so far (progress)
  total       Int       @default(0) // records to score (progress denominator)
  heartbeatAt DateTime? // last liveness write while running
  createdById String? // who triggered (manual); null for system auto-rescore
  createdByName String  @default("")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([status, createdAt]) // claim ordering across projects (oldest queued first)
}

// 62.md — durable, DB-backed ASYNC EXPORT jobs. A large screening export used to run
// k-fold cross-validation AND buffer the whole CSV in memory INSIDE the HTTP request,
// freezing the single Node event loop and 504-ing behind the proxy. Now the request
// only enqueues a job (queued) + returns a jobId; the in-process export worker claims
// it, computes capped CV off the event loop (worker_threads), streams rows to a file,
// and the client polls status then downloads the finished file. Mirrors ScreenImportJob
// (atomic claim, attempts cap, crash recovery). Bare projectId scope key (audit-survival
// precedent, like ScreenAiJob); access is RE-checked at download — a jobId is not a
// capability token. resultPath points at server/storage/exports/<id>.<ext>.
model ScreenExportJob {
  id               String    @id @default(uuid())
  projectId        String
  createdById      String
  createdByName    String    @default("")
  // queued | processing | completed | failed | cancelled
  status           String    @default("queued")
  // queued | loading | cvscoring | rendering | done | failed
  stage            String    @default("queued")
  format           String    @default("csv") // csv | json | ris
  filter           String    @default("all") // all | include | exclude | maybe | undecided
  includeAiCv      Boolean   @default(true) // compute out-of-sample CV columns (capped)
  totalRecords     Int       @default(0)
  processedRecords Int       @default(0)
  cvStatus         String    @default("") // mirror of computeExportCvScores meta.status
  resultPath       String    @default("") // file path of the rendered export (cleared on delete)
  resultBytes      Int       @default(0)
  filename         String    @default("")
  error            String    @default("") // user-facing failure message (status=failed)
  attempts         Int       @default(0) // claims so far (retry-budget cap; poison-pill guard)
  heartbeatAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([status, createdAt]) // claim ordering across projects (oldest queued first)
}

// ════════════════════════════════════════════════════════════════════════════
// PECAN SEARCH ENGINE (P1) — automated literature search via database APIs,
// auto-import, full source provenance, and explainable deduplication.
//
// A "search run" executes a user-authored Boolean strategy against one or more
// open bibliographic providers (PubMed, Europe PMC, ClinicalTrials.gov, Crossref,
// DOAJ, OpenAlex, Semantic Scholar). Each provider runs as an isolated per-source
// task; results are normalized to a canonical record, deduplicated against the
// project's existing records using the SAME explainable engine the screening
// import uses (scorePair / classifyPair), then landed as ScreenRecord rows via
// dedupeAndInsertRecords — so screening, conflicts, fuzzy duplicate detection,
// extraction handoff and PRISMA all consume them UNCHANGED.
//
// Design invariants (see docs/manager/pecan-search/ADRs):
//  - All models are additive + defaulted/nullable → `prisma db push` stays safe.
//  - JSON columns are stored as String (repo convention). Frequently-queried
//    identifiers (doi/pmid) are indexed columns, NOT buried in JSON.
//  - Composite @@unique appear ONLY on brand-new (empty-at-migration) tables,
//    which db push creates cleanly with no --accept-data-loss prompt — they are
//    the explicit idempotency keys P1 requires (a re-run/retry never duplicates a
//    source record or a search run).
//  - metaLabProjectId = the META·LAB Project id (the search workspace, authorized
//    via resolveProjectAccess). screenProjectId = the linked ScreenProject the
//    records land into (resolved at run start). No FK to those tables is declared
//    here (kept as plain indexed strings) to keep the migration purely additive.
//  - After editing, re-run `node scripts/sync-postgres-schema.mjs`.
// ════════════════════════════════════════════════════════════════════════════

// A single execution of a search strategy against one or more providers.
// Reproducibility: canonicalQuery + config are immutable snapshots taken at start.
model PecanSearchRun {
  id               String    @id @default(uuid())
  metaLabProjectId String // META·LAB Project id (search workspace)
  screenProjectId  String    @default("") // resolved ScreenProject landing target
  initiatedById    String    @default("")
  initiatedByName  String    @default("")
  name             String    @default("") // user-facing search name/label
  state            String    @default("queued") // queued|running|partial|completed|cancelled|failed
  canonicalQuery   String    @default("{}") // JSON snapshot of the canonical query (concepts AST + filters)
  canonicalText    String    @default("") // rendered plain-text query (display/report)
  config           String    @default("{}") // JSON snapshot: sources[], caps, dedup opts, filters
  counts           String    @default("{}") // JSON aggregate counts (persisted at finalize; derived from sources)
  warningSummary   String    @default("[]") // JSON run-level warnings
  errorSummary     String    @default("") // sanitized run-level error message
  // Nullable so a no-key start never collides with another no-key start under the
  // composite @@unique below (SQLite/PG treat NULLs as DISTINCT in a unique index);
  // a non-null key makes (project,key) unique so a double-submit/refresh-retry is
  // an atomic no-op (the create races into a P2002 the loser catches).
  idempotencyKey   String? // client-supplied start idempotency key
  jobId            String    @default("") // linked PecanSearchJob id
  softwareVersion  String    @default("")
  engineVersion    String    @default("")
  cancelRequested  Boolean   @default(false) // durable user cancel intent (checked between pages)
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sources        PecanSearchSource[]
  records        PecanSourceRecord[]
  dedupDecisions PecanDedupDecision[]

  @@unique([metaLabProjectId, idempotencyKey])
  @@index([metaLabProjectId, createdAt])
  @@index([state])
}

// Per-source execution state within a run. Each provider is isolated so one
// failing source never fails the whole run (honest partial success).
model PecanSearchSource {
  id                  String         @id @default(uuid())
  runId               String
  run                 PecanSearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  provider            String // pubmed|europepmc|clinicaltrials|crossref|doaj|openalex|semanticscholar
  providerVersion     String         @default("") // connector/translation version
  generatedQuery      String         @default("") // engine-translated query
  finalQuery          String         @default("") // exact executed query (== generated unless overridden)
  queryHash           String         @default("") // stable hash of finalQuery
  translationWarnings String         @default("[]") // JSON warnings from translation
  overrideById        String         @default("") // who supplied a manual override (if any)
  overrideReason      String         @default("")
  filters             String         @default("{}") // JSON source-specific filters/limits
  previewCount        Int? // previewed hit count (null = unknown)
  previewKind         String         @default("") // exact|estimate|unavailable|unsupported
  previewAt           DateTime?
  rawCount            Int            @default(0) // raw records retrieved from provider
  normalizedCount     Int            @default(0)
  importedCount       Int            @default(0) // NET new ScreenRecords landed from this source
  existingMatchCount  Int            @default(0) // matched an existing project record
  exactDupCount       Int            @default(0)
  fuzzyDupCount       Int            @default(0)
  ambiguousDupCount   Int            @default(0)
  failedRecordCount   Int            @default(0) // malformed records skipped (run continues)
  cursor              String         @default("") // resumable provider cursor / page token
  lastCompletedPage   Int            @default(0)
  cap                 Int            @default(0) // effective per-source record cap
  capReached          Boolean        @default(false)
  stage               String         @default("queued") // queued|validating|waiting|counting|fetching|normalizing|deduplicating|importing|finalizing|completed|partial|cancelled|failed|skipped
  state               String         @default("pending") // pending|running|partial|completed|failed|cancelled|skipped
  retryCount          Int            @default(0)
  rateLimitMeta       String         @default("{}") // JSON last-seen rate-limit headers
  errorClass          String         @default("") // typed error code (PROVIDER_RATE_LIMITED, …)
  errorDetail         String         @default("") // sanitized, user-safe detail
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([runId])
  @@index([runId, provider])
}

// An external bibliographic record retrieved from a provider, with full raw +
// normalized provenance. The composite @@unique is the per-source idempotency key:
// re-fetching a page (retry / worker restart) can never persist the same provider
// record twice. screenRecordId links to the landed ScreenRecord (preserved through
// dedup merges so provenance survives).
model PecanSourceRecord {
  id                   String         @id @default(uuid())
  runId                String
  run                  PecanSearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceId             String         @default("") // PecanSearchSource id
  metaLabProjectId     String         @default("")
  provider             String
  providerRecordId     String         @default("") // PMID / DOI / NCT id / OpenAlex work id / content hash fallback
  screenRecordId       String         @default("") // landed ScreenRecord id (provenance link)
  doi                  String         @default("")
  pmid                 String         @default("")
  pmcid                String         @default("")
  nctId                String         @default("")
  title                String         @default("")
  abstract             String         @default("")
  authors              String         @default("")
  year                 String         @default("")
  journal              String         @default("")
  volume               String         @default("")
  issue                String         @default("")
  pages                String         @default("")
  pubType              String         @default("")
  language             String         @default("")
  url                  String         @default("")
  keywords             String         @default("[]") // JSON string[]
  meshTerms            String         @default("[]") // JSON string[]
  retracted            Boolean        @default(false)
  rawPayload           String         @default("{}") // JSON safe snapshot of the provider response item
  normalized           String         @default("{}") // JSON normalized canonical record
  normalizationVersion String         @default("")
  dedupOutcome         String         @default("") // new|existing_match|exact_dup|fuzzy_dup|ambiguous
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([runId, provider, providerRecordId])
  @@index([metaLabProjectId, doi])
  @@index([metaLabProjectId, pmid])
  @@index([sourceId])
  @@index([runId])
}

// A deduplication decision (automatic, identity, or human-confirmed). Stores the
// explainable score, its component signals, the matched target, and the verdict —
// so every merge/keep-separate is auditable and reversible.
model PecanDedupDecision {
  id                    String         @id @default(uuid())
  runId                 String
  run                   PecanSearchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  metaLabProjectId      String         @default("")
  sourceRecordId        String         @default("") // incoming PecanSourceRecord id
  matchedScreenRecordId String         @default("") // matched existing ScreenRecord (if any)
  matchedSourceRecordId String         @default("") // matched in-run source record (if any)
  score                 Int            @default(0) // 0..100
  scoreComponents       String         @default("{}") // JSON signals {titleSim,authorJaccard,yearMatch,doiMatch,pmidMatch,…}
  ruleVersion           String         @default("") // DUP_MODEL_VERSION at decision time
  matchType             String         @default("") // exact|probable|possible|related|family|not|ambiguous
  decision              String         @default("pending") // merged|kept_separate|deferred|pending
  decisionSource        String         @default("") // automatic|manual|identity
  decidedById           String         @default("")
  decidedByName         String         @default("")
  decidedAt             DateTime?
  reasons               String         @default("[]") // JSON string[] human-readable reasons
  conflicts             String         @default("[]") // JSON string[] conflicting fields
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([runId])
  @@index([runId, decision])
  @@index([metaLabProjectId, decision])
}

// Durable background job for a search run. Cloned from the ScreenImportJob pattern
// (DB-backed, single-process, crash-resumable): the run survives browser refresh
// and worker restart; a boot hook re-queues jobs left 'processing' beyond the
// heartbeat lease. claimedBy/leaseUntil are present for a future multi-node lease.
model PecanSearchJob {
  id               String    @id @default(uuid())
  runId            String    @default("")
  metaLabProjectId String    @default("")
  status           String    @default("queued") // queued|processing|completed|failed|cancelled
  stage            String    @default("queued")
  progress         Int       @default(-1) // 0..100, or -1 = indeterminate (unknown total)
  attempts         Int       @default(0)
  claimedBy        String    @default("") // worker instance id (future multi-node lease)
  leaseUntil       DateTime?
  heartbeatAt      DateTime?
  payload          String    @default("{}") // JSON minimal job payload (runId, sources, caps)
  error            String    @default("") // sanitized fatal error
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([runId])
}

// ─── Engine Version Registry (54.md Part 4/7) ───────────────────────────────
// Internal, OPS-ONLY per-engine version tracking. DELIBERATELY DISTINCT from the
// overall app version (package.json / server/version.js), the deployment/commit,
// and the DB schema version — see docs/manager/engine-versions.md. Versions are
// STRUCTURAL (major/minor Int columns, NEVER a float — float arithmetic is unsafe
// for versioning) and rendered as v{major}.{minor}.
//
// The canonical engine CATALOG (stable ids, display names, ownership globs) lives
// in code at src/research-engine/engine-registry/engines.js (code-reviewed,
// merge-conflict-safe, deterministic). These TABLES hold the LIVE version state +
// append-only history (atomic increments, auditability, no production drift). All
// three are brand-new tables, so `prisma db push` stays additive-safe (the @id /
// @@unique below are safe on empty tables — unlike adding them to existing ones).
model EngineRegistry {
  // Stable machine id, e.g. "screening", "network-meta-analysis" (NEVER a display
  // name — renaming an engine in the UI must not orphan its version history).
  id                String   @id
  displayName       String
  description       String?
  major             Int      @default(0)
  minor             Int      @default(1)
  status            String   @default("active") // active|beta|experimental|deprecated
  lastChangeType    String? // "minor" | "major"
  lastChangeSummary String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// One row per version change. The current version is on EngineRegistry; history
// rows keep the full trail (who/what/why/when) for the Ops detail/timeline view.
model EngineVersionHistory {
  id                   String   @id @default(uuid())
  engineId             String
  previousMajor        Int
  previousMinor        Int
  newMajor             Int
  newMinor             Int
  changeType           String // "minor" | "major"
  changeSummary        String
  classificationReason String?
  commitSha            String?
  branch               String?
  actor                String? // automation source ("ci"/"cli") or admin id
  pullRequest          String?
  automatic            Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([engineId, createdAt])
  @@index([commitSha])
}

// Idempotency + concurrency guard: a (changeKey, engineId) pair is processed at
// most once, so re-running the bump for the same commit/manifest never
// double-increments (CI retries, deploy retries, rebases, rerun workflows,
// multiple instances). The @@unique IS the concurrency boundary — a duplicate
// insert raises Prisma P2002 inside the bump transaction and that engine is
// skipped, leaving any concurrent update intact.
model ProcessedEngineChange {
  id        String   @id @default(uuid())
  changeKey String // commit SHA / merged-PR SHA / manifest id
  engineId  String
  createdAt DateTime @default(now())

  @@unique([changeKey, engineId])
  @@index([changeKey])
}

// ═══════════════════════════════════════════════════════════════════════════
// 66.md P4 — AI screening upgrade: citation enrichment, embedding cache,
// representative validation samples. ALL brand-new tables (db-push additive-safe;
// @@unique is fine on empty tables). Scope keys are BARE id strings by repo
// convention (audit-survival: rows outlive the entities they describe).
// ═══════════════════════════════════════════════════════════════════════════

// Global cache of PUBLIC citation metadata keyed by identifier (doi:… / pmid:… /
// oa:W…). Deliberately NOT project-scoped: the payload is public bibliographic
// data (OpenAlex), so cross-project reuse leaks nothing and saves API calls.
model CitationMetadata {
  id        String   @id @default(uuid())
  key       String // normalized identifier: "doi:10.…" | "pmid:12345" | "oa:W…"
  workId    String? // provider work id (OpenAlex W…)
  source    String   @default("openalex")
  status    String   @default("ok") // ok | not_found | error
  payload   String   @default("{}") // JSON {citedByCount, referenceCount, year, refs[], concepts[]}
  fetchedAt DateTime @default(now())
  error     String?

  @@unique([key])
  @@index([workId])
  @@index([fetchedAt])
}

// Persistent embedding cache: (text hash, model) → vector. Backs the in-memory
// LRU in aiEmbeddingClient so re-runs / restarts never re-embed unchanged records.
model EmbeddingCacheEntry {
  id        String   @id @default(uuid())
  textHash  String // FNV-1a/sha of the exact embedding text
  model     String
  dims      Int
  vector    String // JSON number[]
  createdAt DateTime @default(now())

  @@unique([textHash, model])
  @@index([model])
}

// Representative random validation seed sample (66.md P4.6). Stores the sampling
// seed + method + membership so unbiased-vs-prioritized label provenance is
// reconstructable and the CV metrics can be split honestly.
model ScreenValidationSample {
  id            String   @id @default(uuid())
  projectId     String // ScreenProject id (bare scope key)
  stage         String   @default("title_abstract")
  seed          Int
  method        String   @default("uniform_random") // uniform_random (stratified later)
  size          Int
  recordIds     String   @default("[]") // JSON string[] of ScreenRecord ids
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([projectId, stage, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// 66.md P5 — structured data extraction with dual extraction + adjudication +
// provenance + AI assist (flag `extractionAssist`). projectId here is the
// META·LAB Project id (extraction lives on the project workspace); studyId is
// the in-blob 8-char study uid (same convention as RobAssessment.studyId).
// armKey is "" for study-level values (never NULL inside a unique key).
// ═══════════════════════════════════════════════════════════════════════════

model ExtractionForm {
  id          String   @id @default(uuid())
  projectId   String
  name        String   @default("Extraction form")
  templateKey String? // template it was seeded from
  elements    String   @default("[]") // JSON element definitions (research-engine/extraction/model.js)
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, isActive])
}

// One extractor value for one element (and arm) of one study. Extractor rows
// are NEVER overwritten by adjudication — consensus lives in its own table.
model ExtractionValue {
  id           String   @id @default(uuid())
  projectId    String
  formId       String
  studyId      String
  elementId    String
  armKey       String   @default("") // "" = study-level
  userId       String
  userName     String?
  value        String   @default("{}") // JSON canonical value object
  provenance   String   @default("{}") // JSON {type, excerpt, location, page, table, row, col}
  origin       String   @default("manual") // manual | ai_accepted | ai_edited
  suggestionId String? // AiExtractionSuggestion id when AI-assisted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, studyId, elementId, armKey, userId])
  @@index([projectId, studyId])
  @@index([projectId, userId])
}

model ExtractionAssignment {
  id            String   @id @default(uuid())
  projectId     String
  studyId       String
  extractor1Id  String?
  extractor2Id  String?
  adjudicatorId String?
  status        String   @default("single") // single | dual | adjudicating | consensus
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, studyId])
  @@index([projectId])
}

// The adjudicated/agreed FINAL value per element+arm of a study. Audit fields
// record who resolved it and from which side; extractor rows stay untouched.
model ExtractionConsensus {
  id             String   @id @default(uuid())
  projectId      String
  studyId        String
  elementId      String
  armKey         String   @default("")
  value          String   @default("{}") // JSON canonical value object
  source         String   @default("agreement") // agreement | accept_a | accept_b | adjudicated
  aiAssisted     Boolean  @default(false)
  note           String?
  provenance     String   @default("{}")
  resolvedById   String?
  resolvedByName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, studyId, elementId, armKey])
  @@index([projectId, studyId])
}

// AI extraction suggestions — proposals ONLY; they can never auto-commit into
// ExtractionValue/ExtractionConsensus (human review is mandatory, 66.md P5.4).
model AiExtractionSuggestion {
  id          String   @id @default(uuid())
  projectId   String
  studyId     String
  provider    String   @default("heuristic") // heuristic | external
  model       String? // provider model/version for the audit trail
  payload     String   @default("[]") // JSON [{elementId, armKey, value, confidence, provenance, notFound, ambiguity}]
  status      String   @default("proposed") // proposed | reviewed
  createdById String?
  createdAt   DateTime @default(now())

  @@index([projectId, studyId, createdAt])
}

model ParsedTable {
  id          String   @id @default(uuid())
  projectId   String
  studyId     String?
  name        String? // caption / user label
  source      String   @default("paste") // paste | html | csv | pdf
  page        Int?
  data        String   @default("[]") // JSON string[][] rows
  quality     Float? // 0..1 parse-quality score
  createdById String?
  createdAt   DateTime @default(now())

  @@index([projectId, studyId])
}

// ═══════════════════════════════════════════════════════════════════════════
// 66.md P6 — living reviews (flag `livingReview`): scheduled saved searches,
// reproducible review snapshots, evidence-shift alerts. metaLabProjectId is the
// Project id (bare scope key, same convention as PecanSearchRun).
// ═══════════════════════════════════════════════════════════════════════════

model LivingSavedSearch {
  id               String    @id @default(uuid())
  metaLabProjectId String
  name             String    @default("Living search")
  providerIds      String    @default("[]") // JSON provider ids subset (pecan providers)
  canonicalQuery   String    @default("{}") // JSON canonical query AST snapshot — the EXACT re-runnable query
  canonicalText    String    @default("") // human-readable rendering of the query at save time
  cadence          String    @default("manual") // manual | daily | weekly | monthly
  enabled          Boolean   @default(true)
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  lastRunId        String? // PecanSearchRun id
  lastRunState     String? // completed | partial | failed | cancelled
  lastResultCount  Int?
  lastNewCount     Int?
  lastError        String?
  notes            String?
  createdById      String?
  createdByName    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([metaLabProjectId])
  @@index([enabled, nextRunAt])
}

// Reproducible review snapshot: summary-only (references + derived counts + MA
// results), never a full data copy — snapshots stay small on large projects.
model ReviewSnapshot {
  id               String   @id @default(uuid())
  metaLabProjectId String
  kind             String   @default("manual") // manual | update
  label            String?
  runId            String? // PecanSearchRun that triggered an update snapshot
  appVersion       String?
  summary          String   @default("{}") // JSON summary (living/snapshotDiff.js shape)
  createdById      String?
  createdByName    String?
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId, createdAt])
}

model EvidenceShiftAlert {
  id               String    @id @default(uuid())
  metaLabProjectId String
  snapshotId       String
  prevSnapshotId   String?
  severity         String    @default("info") // info | notable | major
  shifts           String    @default("[]") // JSON detectEvidenceShift().shifts
  status           String    @default("open") // open | acknowledged
  acknowledgedById String?
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())

  @@index([metaLabProjectId, status, createdAt])
}

// 67.md — PRODUCT TIER definitions (the entitlement plans normal users are
// assigned to). Brand-new table (db-push additive-safe). Rows are seeded from
// the code defaults in src/shared/entitlements.js at boot (create-if-missing,
// never overwrite) and are ADMIN-EDITABLE from Ops -> Tiers; the resolver merges
// code defaults UNDER a row's entitlements JSON so new keys ship without
// migrations. Billing integration fields are deliberately deferred.
model ProductTier {
  id           String   @id // stable machine id: 'free' | 'plus' | 'pro' | custom
  name         String
  displayName  String
  description  String   @default("")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  entitlements String   @default("{}") // JSON { "screening.aiScoring": true, "projects.maxActiveProjects": 3, ... } (-1 = unlimited)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
