  note             String?
  createdById      String?
  createdByName    String?
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId, version])
}

// ─────────────────────────────────────────────────────────────────────────────
// P10 — Criteria-based eligibility screening (flag `eligibilityScreening`, OFF).
// A project defines an ordered, versioned set of inclusion/exclusion CRITERIA; a
// deterministic engine answers each criterion per record (yes/no/unclear +
// confidence + evidence quote) and proposes include/exclude/unclear. Nothing ever
// commits a human decision unless BOTH the project policy AND the global policy
// enable governed auto-apply (killSwitch-guarded, reversible, fully audited).
// All brand-new empty tables → `prisma db push` additive-safe.
// ─────────────────────────────────────────────────────────────────────────────

// One eligibility criterion (question) for a project. Ordered + versioned; the whole
// set is replaced atomically and its `version` bumped on every edit so an assessment
// can record exactly which criteria version produced it.
model EligibilityCriterion {
  id         String   @id @default(uuid())
  projectId  String
  key        String   @default("") // stable slug used by the engine + evidence map
  category   String   @default("") // population | intervention | comparator | outcome | studyDesign | other
  question   String   @default("") // human-readable eligibility question
  kind       String   @default("include") // include | exclude
  required   Boolean  @default(false) // a failed REQUIRED criterion blocks inclusion
  polarity   String   @default("positive") // positive | negative (how a 'yes' maps to eligibility)
  orderIndex Int      @default(0)
  version    Int      @default(1) // criteria-set version this row belongs to
  active     Boolean  @default(true)
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

// Append-only edit history of a project's criteria set (who changed what, when).
model EligibilityCriterionAudit {
  id            String   @id @default(uuid())
  projectId     String
  version       Int      @default(1) // resulting criteria-set version
  changeType    String   @default("replace") // replace | create | delete
  beforeJson    String   @default("[]") // criteria set before the change (JSON)
  afterJson     String   @default("[]") // criteria set after the change (JSON)
  changedById   String?
  changedByName String   @default("")
  createdAt     DateTime @default(now())

  @@index([projectId])
}

// One eligibility assessment per (project, record): the engine's per-criterion answers
// + suggested decision, plus governed auto-apply / reviewer-override provenance. Every
// value is reviewable, reversible, and traceable.
model EligibilityAssessment {
  id                 String    @id @default(uuid())
  projectId          String
  recordId           String
  stage              String    @default("title_abstract")
  answersJson        String    @default("[]") // per-criterion answers (answer/confidence/evidenceQuote/sourceField)
  blockersJson       String    @default("[]") // failed required criteria that block inclusion
  suggestedDecision  String    @default("unclear") // include | exclude | unclear
  decisionConfidence Float?
  engineVersion      String    @default("") // provenance: engine version that produced it
  configVersion      String    @default("") // provenance: engine config version
  criteriaVersion    Int       @default(1) // provenance: criteria-set version scored against
  autoApplied        Boolean   @default(false) // did governed auto-apply write a decision?
  autoApplyPolicy    String    @default("") // policy in force at eval time (assist | auto)
  autoAppliedAt      DateTime? // provenance: when auto-apply fired
  reviewerDecision   String    @default("") // include | exclude — human adjudication
  reviewerId         String?
  reviewerName       String    @default("")
  overrideReason     String    @default("")
  decidedAt          DateTime? // when a reviewer (or governed auto-apply) settled it
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([projectId, recordId])
  @@index([projectId])
}

// P10 bulk-evaluation jobs — a durable, crash-recoverable background worker mirroring
// ScreenAiJob (atomic claim, attempts cap, heartbeat, progress). Kept PARALLEL to the AI
// job table (separate ownership surface); the eligibility compute lives in the eligibility
// service. Bare projectId scope key (audit-survival precedent, like ScreenAiJob).
model ScreenEligibilityJob {
  id            String    @id @default(uuid())
  projectId     String
  stage         String    @default("title_abstract")
  scope         String    @default("undecided") // all | undecided | ids
  recordIdsJson String    @default("[]") // explicit ids when scope = ids
  autoApply     Boolean   @default(false) // whether governed auto-apply may run this batch
  status        String    @default("queued") // queued | running | completed | failed | superseded | cancelled
  trigger       String    @default("manual") // manual | api
  reason        String    @default("") // failure reason (no article text)
  nAssessed     Int       @default(0)
  nAutoApplied  Int       @default(0)
  attempts      Int       @default(0)
  processed     Int       @default(0)
  total         Int       @default(0)
  durationMs    Int?
  heartbeatAt   DateTime?
  createdById   String?
  createdByName String    @default("")
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([status, createdAt])
}

// Per-project eligibility policy (owner/leader editable). Kept in its own table (one
// row per project) so the whole schema change stays an EOF append — mirrors the role
// of ScreenProject.aiSettings without editing that model. Governs whether governed
// auto-apply may run for the project and its confidence gates (bounded by the global
// policy + killSwitch). Brand-new empty table → `prisma db push` additive-safe.
model EligibilityProjectSetting {
  id           String   @id @default(uuid())
  projectId    String   @unique
  settingsJson String   @default("{}") // { enabled, policy, includeConfidence, excludeConfidence }
  updatedById  String?
  updatedByName String  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// P11 — Guided Boolean search-strategy Studio (flag `searchStrategyStudio`, OFF;
// functionally depends on `searchEngine` + `pecanSearch`). A generator↔critic loop
// refines a per-database Boolean strategy using the REAL per-DB hit counts already
// produced by the Pecan Search connectors. Every iteration's provenance (the exact
// string evaluated, its live hit count, the critic's assessment, what changed, and
// the timestamp) is persisted so the refinement trail is fully reproducible. Recall
// is estimated against a NEW project-scoped seed-study (known-included) set — the gap
// this feature closes. All brand-new empty tables → `prisma db push` additive-safe.
// ─────────────────────────────────────────────────────────────────────────────

// One generator↔critic iteration for one database. Persisted per loop step so the
// full optimisation trail (executed string + hit count + critic notes + changes) is
// auditable and never reconstructed approximately.
model SearchStrategyIteration {
  id                String   @id @default(uuid())
  metaLabProjectId  String
  strategyVersionId String? // optional link to a frozen SearchStrategyVersion
  iteration         Int      @default(1) // 1-based loop step
  database          String   @default("")
  searchString      String   @default("") // the exact query string evaluated this step
  hitCount          Int? // real per-DB count (null when unavailable/timeout/unsupported)
  hitKind           String   @default("") // exact | estimate | unavailable | timeout | unsupported
  criticJson        String   @default("{}") // JSON: critic assessment (issues/score/suggestedEdits)
  changesJson       String   @default("{}") // JSON: what changed vs the previous step
  profile           String   @default("") // generator profile/label for this DB
  createdById       String?
  createdAt         DateTime @default(now())

  @@index([metaLabProjectId])
}

// A project's known-included / seed studies used for recall estimation. This is the
// GAP P11 closes — no prior per-project seed set existed. Identifiers are all optional
// (a seed may be known only by title); recall matching prefers DOI/PMID/OpenAlex id.
model SearchSeedStudy {
  id               String   @id @default(uuid())
  metaLabProjectId String
  title            String   @default("")
  doi              String?
  pmid             String?
  openAlexId       String?
  source           String   @default("manual") // manual | import | run
  addedById        String?
  addedByName      String?
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId])
}

// A persisted recall estimate: seed coverage of a completed run's retrieved set
// (source 'run') OR a per-seed membership probe against PubMed (source 'probe').
// estimatedRecall is nullable (undefined when seedTotal = 0). missingJson carries the
// not-found seeds plus query-improvement suggestions.
model SearchRecallReport {
  id                String   @id @default(uuid())
  metaLabProjectId  String
  strategyVersionId String?
  runId             String?
  seedTotal         Int      @default(0)
  foundCount        Int      @default(0)
  estimatedRecall   Float?
  missingJson       String   @default("[]") // JSON: { notFound[], suggestions[] }
  createdAt         DateTime @default(now())

  @@index([metaLabProjectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// P12 — GRADE certainty of evidence + Summary of Findings (flag `gradeCertainty`,
// OFF). A per-OUTCOME, audited, lockable certainty layer that sits ALONGSIDE the
// legacy blob-based (primary-outcome-only) GRADE tab — the legacy tab is untouched
// when the flag is off. Each row is one GRADE assessment for one outcome pair
// (getOutcomePairs key = "outcome|||timepoint"). Domain ratings are stored engine-
// agnostically (CINeMA-ready) as JSON; the pure engine (src/research-engine/grade)
// computes the certainty level. Suggestions are NEVER auto-final — a domain becomes
// authoritative only when a human SAVES it (source:'manual'). Every save / lock /
// unlock writes a GradeAuditLog row; lock is reversible + logged. Brand-new empty
// tables → `prisma db push` additive-safe; bare-string ids (no cross-project FKs);
// all non-key columns nullable or @default; JSON stored as String.
// ─────────────────────────────────────────────────────────────────────────────

// One GRADE certainty assessment for one outcome of one META·LAB project. Unique per
// (project, outcomeKey). `domainsJson` holds the per-domain ratings the reviewer has
// confirmed (source:'manual') or that were carried from an engine suggestion
// (source:'auto'); the certainty level is recomputed by the pure engine on every save.
model GradeOutcomeAssessment {
  id               String    @id @default(uuid())
  metaLabProjectId String
  outcomeKey       String // stable per-outcome key (getOutcomePairs: "outcome|||timepoint")
  outcomeLabel     String    @default("")
  startLevel       Int       @default(4) // numeric start (4=High/RCT … 2=Low/observational)
  startLevelSource String    @default("") // e.g. "design:RCT" | "manual"
  domainsJson      String    @default("{}") // JSON: { [domainId]: { rating, source:'auto'|'manual', note } }
  suggestionsJson  String    @default("{}") // JSON: engine suggestion snapshot at save time (provenance)
  certaintyLevel   String    @default("") // e.g. "high" | "moderate" | "low" | "very_low"
  certaintyNumeric Int? // 1..4 (null until computed)
  robSignature     String    @default("") // RoB→GRADE staleness signature captured at save time
  locked           Boolean   @default(false)
  lockedById       String?
  lockedByName     String?
  lockedAt         DateTime?
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([metaLabProjectId, outcomeKey])
  @@index([metaLabProjectId])
}

// Append-only audit trail for every GRADE change (save / lock / unlock). before/after
// snapshots make each certainty decision fully reconstructable.
model GradeAuditLog {
  id               String   @id @default(uuid())
  metaLabProjectId String
  outcomeKey       String   @default("")
  action           String   @default("") // SAVE | LOCK | UNLOCK
  beforeJson       String   @default("{}")
  afterJson        String   @default("{}")
  changedById      String?
  changedByName    String?
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId])
}

// ═══════════════════════════════════════════════════════════════════════════
// P15 — Bibliomine citation mining. ALL brand-new tables (db-push additive-safe;
// @@index is fine on empty tables). Every non-key column is nullable / defaulted;
// ids are BARE strings (no cross-project FKs) by repo convention so provenance
// rows outlive the entities they describe (audit survival). JSON stored as String.
// Gated by the `citationMining` feature flag (default OFF → endpoints 404).
// ═══════════════════════════════════════════════════════════════════════════

// An uploaded "seed review" (a prior systematic review / PDF) whose reference list
// is mined. Only client-extracted TEXT reaches the server (no file bytes stored);
// fileHash lets a re-upload of the same document be recognised.
model SeedReview {
  id               String   @id @default(uuid())
  metaLabProjectId String
  title            String   @default("")
  filename         String   @default("")
  fileHash         String   @default("")
  uploadedById     String?
  uploadedByName   String?
  referenceCount   Int      @default(0)
  textChars        Int?
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId])
}

// One parsed bibliographic reference extracted from a SeedReview's reference list.
// `parseConfidence` is the pure engine's confidence; the `resolved*` columns hold
// the outcome of resolving the reference to a canonical record (DOI/PMID/OpenAlex).
model ExtractedReference {
  id                 String   @id @default(uuid())
  seedReviewId       String
  metaLabProjectId   String   @default("")
  orderIndex         Int      @default(0)
  raw                String   @default("")
  authors            String   @default("")
  title              String   @default("")
  journal            String   @default("")
  year               String   @default("")
  doi                String   @default("")
  pmid               String   @default("")
  url                String   @default("")
  parseConfidence    Float?
  resolutionStatus   String   @default("pending") // pending|resolved|not_found|error
  resolvedJson       String   @default("{}")
  resolvedSource     String   @default("") // reference|crossref|openalex|pubmed
  resolvedDoi        String   @default("")
  resolvedPmid       String   @default("")
  resolvedOpenAlexId String   @default("")
  createdAt          DateTime @default(now())

  @@index([seedReviewId])
  @@index([metaLabProjectId])
}

// Durable, crash-resumable citation-chase job. Cloned from the PecanSearchJob
// pattern: a boot hook re-queues jobs left 'processing' beyond the heartbeat lease
// (under a retry cap → poison pills fail permanently, never loop). Bounded by
// `depth` (≤3) and `maxCandidates` so external fan-out can never run away.
model CitationChaseJob {
  id               String    @id @default(uuid())
  metaLabProjectId String    @default("")
  direction        String    @default("backward") // backward (cited-by references) | forward (citing works)
  depth            Int       @default(1)
  maxCandidates    Int       @default(500)
  seedIdsJson      String    @default("[]") // JSON string[] of ExtractedReference ids
  status           String    @default("queued") // queued|processing|completed|failed|cancelled
  progress         Int       @default(0) // 0..100
  total            Int?
  nFound           Int       @default(0)
  attempts         Int       @default(0)
  heartbeatAt      DateTime?
  leaseUntil       DateTime?
  claimedBy        String    @default("") // worker instance id (future multi-node lease)
  cancelRequested  Boolean   @default(false)
  errorText        String    @default("")
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([metaLabProjectId])
  @@index([heartbeatAt])
}

// A candidate record surfaced by citation mining (a resolved reference, a backward
// citation, or a forward citing work) BEFORE it is imported into screening.
// `provenanceJson` records which seed/study/job produced it; `imported` flips once
// it lands as a ScreenRecord (via a source:'citation-mining' ScreenImportBatch).
model CitationCandidate {
  id               String   @id @default(uuid())
  metaLabProjectId String   @default("")
  chaseJobId       String?
  seedReviewId     String?
  doi              String   @default("")
  pmid             String   @default("")
  openAlexId       String   @default("")
  title            String   @default("")
  abstract         String   @default("")
  year             String   @default("")
  journal          String   @default("")
  authorsJson      String   @default("[]")
  publicationType  String   @default("")
  source           String   @default("") // reference|backward|forward
  provenanceJson   String   @default("{}")
  dedupStatus      String   @default("") // new|existing_match|exact_dup|fuzzy_dup|ambiguous
  matchedRecordId  String   @default("")
  imported         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([metaLabProjectId])
  @@index([chaseJobId])
}

// ═══════════════════════════════════════════════════════════════════════════
// 72.md — User Tier Management infrastructure (EXTENDS 67.md's ProductTier +
// entitlement backbone; the two never mix with app/system role or project role).
//
// THREE clean concepts stay SEPARATE (never one messy field):
//   - Tier         : what level of access a user has (User.tierId → ProductTier)
//   - Entitlement  : the features/limits a tier grants (src/shared/entitlements)
//   - Subscription : the billing/payment lifecycle (TierSubscription — PLACEHOLDER)
//
// UserTierAssignment is the append-only HISTORY of every tier a user has been in
// (who/why/when/how). Exactly one row per user is `isCurrent = true`. The
// authoritative "which tier is the user in NOW" stays on User.tierId; each
// mutation writes BOTH in lock-step (see entitlementService.recordTierAssignment).
// All fields additive/nullable/defaulted so `prisma db push` stays safe.
// ═══════════════════════════════════════════════════════════════════════════
model UserTierAssignment {
  id             String    @id @default(uuid())
  userId         String
  tierId         String // concrete ProductTier id this assignment placed the user in
  previousTierId String? // the tier they were in before (null = no prior / initial)
  assignedById   String? // admin user id who made the change (null = system/backfill)
  assignedByName String? // denormalised display name for the history table
  // manual | promotion | downgrade | trial_start | trial_end | beta_access |
  // institution | payment | support_override | correction | backfill | other
  changeType     String    @default("manual")
  reason         String    @default("")
  notes          String    @default("")
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime? // optional scheduled expiry (e.g. trial ends later)
  isCurrent      Boolean   @default(true)
  reverted       Boolean   @default(false)
  revertedAt     DateTime?
  revertedById   String?
  metaJson       String    @default("{}") // JSON: { system, followDefault, revertOf, ... }
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([tierId])
  @@index([userId, isCurrent])
}

// TierSubscription — BILLING PLACEHOLDER (no payment processing yet). One row per
// user (upserted). Fields mirror a generic provider (Stripe-shaped) so a future
// billing integration can populate them WITHOUT touching the tier/entitlement
// engine. status defaults to "none" (no subscription). Never exposed to normal
// users; admin-only read/write.
model TierSubscription {
  id                     String    @id @default(uuid())
  userId                 String
  tierId                 String?
  provider               String? // e.g. "stripe" (future)
  providerCustomerId     String?
  providerSubscriptionId String?
  priceId                String?
  planId                 String?
  status                 String    @default("none") // none | trialing | active | past_due | canceled
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialStart             DateTime?
  trialEnd               DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  lastPaymentAt          DateTime?
  nextRenewalAt          DateTime?
  failedPaymentCount     Int       @default(0)
  notes                  String    @default("")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([userId])
  @@index([userId])
}
