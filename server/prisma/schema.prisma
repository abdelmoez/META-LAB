// META·LAB Prisma schema
// Provider: SQLite (via Prisma ORM)
// Auth: users own projects — userId enforced on every query

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                   @id @default(uuid())
  // prompt49 item 8 / Postgres-readiness — immutable, sequential, admin-VISIBLE
  // numeric user id (distinct from the internal uuid `id`). Allocated atomically
  // from the "userNumber" AppSequence counter (NEVER MAX(id)+1) so it is
  // collision-free under concurrency and portable across SQLite and PostgreSQL
  // (a native SEQUENCE backs it after the PG migration). Nullable so `prisma db
  // push` stays additive-safe; backfilled in createdAt,id order and assigned at
  // registration. NEVER editable from the Ops console (see editableUserFields).
  // Plain @@index (NOT @unique) below: a unique constraint would force the VPS
  // `prisma db push` deploy to demand --accept-data-loss (which it never passes —
  // same reasoning as inviteTokenHash / PasswordResetToken.tokenHash). Uniqueness
  // is guaranteed by construction: the AppSequence allocator hands out each value
  // exactly once inside a transaction.
  userNumber                    Int?
  email                         String                   @unique
  name                          String?
  password                      String // bcrypt hash — never stored or returned as plain text
  role                          String                   @default("user") // "user" | "admin"
  suspended                     Boolean                  @default(false)
  // prompt49 — session revocation. Every issued JWT carries the user's sessionEpoch
  // at sign time; requireAuth rejects a token whose epoch is behind the DB value.
  // Incremented on SUSPEND and on PASSWORD CHANGE → all existing sessions across
  // devices are invalidated immediately (and unsuspend does NOT restore them: the
  // epoch stays bumped, so old tokens never become valid again). Additive default 0.
  sessionEpoch                  Int                      @default(0)
  suspendedAt                   DateTime? // when the account was last suspended (audit/forensics)
  // 67.md — PRODUCT TIER (separate from the app/system `role` above and from
  // per-project roles on ScreenProjectMember; the three systems never mix).
  // null → the user resolves to the site default tier at READ time (config/env),
  // so existing users need no backfill and flipping the default is instant.
  // Admins/mods bypass tier limits entirely (enforced in entitlementService).
  tierId                        String? // ProductTier id ('free'|'plus'|'pro'|custom)
  tierAssignedAt                DateTime?
  tierAssignedBy                String? // admin user id (audit; AdminAuditLog carries the rest)
  tierOverrideReason            String? // optional note recorded at assignment
  passwordChangedAt             DateTime? // when the password last changed (session-revocation forensics)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  lastActive                    DateTime?
  themePreference               String? // "night" | "day" — UI theme, synced from the account menu toggle
  // prompt23 Task 2 (follow-up) — per-user dashboard view preferences as a small
  // JSON blob: { sort, filter, view, showArchived }. Nullable → `prisma db push`
  // stays additive-safe. Mirrors themePreference; cross-device, server-backed.
  dashboardPreferences          String?
  // prompt25 Task 7 — per-user Screening keyboard-shortcut preferences as a small
  // JSON blob: { enabled, keys: { next, previous, include, exclude, maybe, undo } }.
  // Nullable → `prisma db push` stays additive-safe. Mirrors dashboardPreferences;
  // cross-device, server-backed.
  screeningShortcuts            String?
  // prompt39 Task 5 — per-user left workflow-menu mode: "pinned" (stay open, never
  // auto-collapse on workflow navigation) | "auto" (auto-collapse on workflow
  // steps). null ⇒ "auto" (current default). Nullable → `prisma db push` stays
  // additive-safe. Mirrors themePreference; cross-device, server-backed.
  workflowMenuMode              String?
  // 56.md §6 — pin the project workspace purple sidebar open. null ⇒ collapsed
  // by default (hover/focus still expands temporarily); true ⇒ kept expanded.
  // Nullable Boolean → `prisma db push` stays additive-safe; cross-device.
  projectSidebarPinned          Boolean?
  // design.md — parallel design-mode preference: "legacy" (default UI) | "stitch"
  // (the new Vivid-Enterprise research-OS UI). ADMIN-ONLY: the server refuses to
  // persist "stitch" for a non-admin (profileController). null ⇒ "legacy".
  // Nullable → `prisma db push` stays additive-safe. Cross-device, server-backed.
  uiDesignMode                  String?
  // prompt19 — aggregate ops analytics only. COUNTRY-LEVEL ONLY; no city/coords.
  // Captured best-effort at registration from a proxy country header (e.g.
  // CF-IPCountry) or an offline lookup; raw IP is never stored (only an optional
  // salted hash). All nullable → `prisma db push` stays additive-safe.
  registrationCountryCode       String? // ISO-3166 alpha-2 (e.g. "US"), or null/"" when unknown
  registrationCountryName       String? // human-readable country name, or null when unknown
  registrationIpCountrySource   String? // "header" | "geoip" | "local" | "none"
  registrationIpHash            String? // optional salted SHA-256 of the IP — NEVER the raw IP
  registrationCountryDetectedAt DateTime? // prompt32 — when country was resolved at registration
  // prompt26 — email verification (OFF by default via appSettings.requireEmailVerification).
  // Mirrors the PasswordResetToken ceremony but inline on User: only the SHA-256
  // HASH of the verify token is stored (plaintext lives only in the email link),
  // single-use (hash nulled on verify), short-lived (expiresAt). All nullable →
  // `prisma db push` stays additive-safe. emailVerifiedAt=null ⇒ unverified.
  emailVerifiedAt               DateTime?
  emailVerificationTokenHash    String? // SHA-256 hex; nulled when consumed
  emailVerificationExpiresAt    DateTime?
  termsAcceptedAt               DateTime? // prompt26 — when the user agreed to Terms & Privacy
  // prompt26 — optional onboarding profile (skippable; never blocks app access).
  // All nullable/additive. institutionOriginal preserves the EXACT user text;
  // institutionNormalized is the matching key (see research-engine institutionMatch).
  primaryRole                   String? // Student | Researcher | Faculty/PI | …
  researchField                 String? // Health sciences | Psychology | …
  mainUseCase                   String? // Systematic review | Meta-analysis | …
  institutionOriginal           String? // exact text the user typed
  institutionNormalized         String? // normalized matching key
  // prompt35 — canonical institution linkage (ROR registry or a matched local
  // canonical). ADDITIVE + nullable so `prisma db push` stays safe; the typed text
  // above is always preserved. institutionRorId is the ROR id URL when a canonical
  // ROR record was selected; institutionNeedsReview flags an uncertain custom match
  // for Ops (never silently merged).
  institutionRorId              String? // e.g. https://ror.org/03vek6s52 (null = custom/local)
  institutionCanonicalName      String? // canonical display name (ROR or matched local)
  institutionCity               String?
  institutionCountryName        String? // canonical institution country (distinct from user-stated `country`)
  institutionCountryCode        String? // ISO-3166 alpha-2
  institutionSource             String? // "ror" | "local" | "custom"
  institutionMatchConfidence    Float? // 0..1 confidence of the canonical link
  institutionNeedsReview        Boolean                  @default(false) // uncertain custom match → Ops review
  // prompt36 follow-up — link to the canonical Institution cache row (nullable;
  // null for custom/unmatched). Additive FK → `prisma db push` stays safe.
  institutionId                 String?
  institution                   Institution?             @relation(fields: [institutionId], references: [id])
  country                       String? // user-stated country/region (onboarding)
  onboardingCompletedAt         DateTime? // null ⇒ onboarding not completed/skipped-not-done
  projects                      Project[]
  auditLogs                     AdminAuditLog[]
  screenProjects                ScreenProject[]          @relation("UserScreenProjects")
  screenMemberships             ScreenProjectMember[]    @relation("UserScreenMemberships")
  passwordResetTokens           PasswordResetToken[]
  onboardingResponses           UserOnboardingResponse[] // prompt32 — per-question onboarding state

  @@index([userNumber])
}

// Application-managed monotonic counters (provider-portable sequences). Prisma
// can't put `@default(autoincrement())` on a non-PK column on SQLite, and a naïve
// MAX(col)+1 is racy, so durable monotonic ids (the user-facing numeric
// User.userNumber today) are allocated by atomically incrementing a named counter
// row INSIDE a transaction (see server/services/sequence.js). One row per logical
// sequence. On PostgreSQL this is replaced by a native SEQUENCE at migrate time,
// but the same allocator code keeps working unchanged. Brand-new table → `prisma
// db push` creates it cleanly (no --accept-data-loss).
model AppSequence {
  name      String   @id // logical sequence name, e.g. "userNumber"
  value     Int      @default(0) // last allocated value; next = value + 1
  updatedAt DateTime @updatedAt
}

// prompt36 follow-up — canonical institution cache (ROR/local). Populated when a
// user selects/links a canonical institution; brand-new table → `prisma db push`
// stays additive-safe (rorId @unique is safe on an empty table). The denormalized
// institution* columns on User are kept; this adds a shared canonical row users
// link to (institutionId) for institution-level rollups.
model Institution {
  id             String   @id @default(uuid())
  canonicalName  String
  normalizedName String // institutionMatch.normalizeInstitution key
  rorId          String?  @unique // ROR id URL (null for local-only canonicals)
  openAlexId     String?
  countryName    String?
  countryCode    String?
  city           String?
  website        String?
  aliases        String? // JSON array of alternative spellings
  source         String   @default("local") // "ror" | "openalex" | "local"
  needsReview    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]

  @@index([normalizedName])
}

// prompt32 Task 6 — generic, ops-managed onboarding questions. The legacy
// User.onboardingCompletedAt + 5 fixed profile columns stay for analytics/back-compat;
// these two tables add a PER-QUESTION layer so newly-added questions can re-interrupt
// already-registered users on their next login, and answered/skipped state is tracked
// per (user, question). Brand-new tables → `prisma db push` stays additive-safe.
model OnboardingQuestion {
  id           String                   @id @default(uuid())
  key          String                   @unique // stable slug, e.g. "primary_role"
  prompt       String // question text shown to the user
  description  String? // optional helper text
  type         String                   @default("single_select") // text|single_select|multi_select|boolean|number|date
  options      String? // JSON array of { value, label } for *_select types
  isActive     Boolean                  @default(true) // ops on/off without delete (soft)
  isRequired   Boolean                  @default(false) // when true, the question cannot be skipped
  allowSkip    Boolean                  @default(true) // when false (and not required), still no skip
  displayOrder Int                      @default(0)
  audience     String? // optional JSON rule (reserved; null = everyone)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  responses    UserOnboardingResponse[]

  @@index([isActive, displayOrder])
}

model UserOnboardingResponse {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   OnboardingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     String? // JSON-encoded answer value; null when skipped
  status     String             @default("answered") // "answered" | "skipped"
  answeredAt DateTime?
  skippedAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, questionId]) // one row per (user, question)
  @@index([userId])
}

// Single-use, time-limited password-reset token (prompt14 Task 4).
// Mirrors the invite-token ceremony: only the SHA-256 HASH of the random token
// is stored — the plaintext lives only in the email link / operator response and
// is never logged. Single-use via `usedAt`; short-lived via `expiresAt`. Lookup
// is a plain @@index (NOT @unique) so `prisma db push` (the VPS deploy path) never
// needs --accept-data-loss; 256-bit tokens + single-use nulling make uniqueness moot.
model PasswordResetToken {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String // SHA-256 hex of the raw token; plaintext never stored
  expiresAt         DateTime // validity window (now + PASSWORD_RESET_TTL_MINUTES)
  usedAt            DateTime? // set when consumed — single-use marker
  requestedByUserId String? // admin/mod who initiated; null = self-service forgot-password
  ip                String    @default("")
  createdAt         DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId, createdAt])
}

model Project {
  id                   String                @id @default(uuid())
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  data                 String                @default("{}") // JSON-serialised project payload (studies, records, pico, search, etc.)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  deletedSource        String? // prompt9 — 'owner' | 'admin'; legacy null = admin archive
  archived             Boolean               @default(false) // prompt11 — user-facing archive (reversible hide)
  archivedAt           DateTime? // prompt11 — when archived
  lastSavedAt          DateTime?
  // prompt50 WS5 — authoritative MEANINGFUL-activity timestamp for "Last Modified"
  // sorting. Distinct from the Prisma @updatedAt column (which a bare row-touch
  // bumps): this is set only by meaningful user activity — a real blob edit, or a
  // linked-module action (screening decision/import/conflict resolution, RoB)
  // routed through touchProjectActivity(). Nullable + indexed → `prisma db push`
  // stays additive-safe; backfilled at boot from updatedAt/createdAt.
  lastActivityAt       DateTime?
  // roadmap 0.2 — additive virtual back-relations (no column on Project). The
  // Project.data JSON blob stays the source of truth until the
  // relationalProjectStore feature flag is flipped at an evaluation gate.
  reviewRecords        ReviewRecord[]
  reviewStudies        ReviewStudy[]
  // rob.md — META·LAB RoB: outcome/result-level Risk-of-Bias assessments.
  // Additive back-relation only (no column on Project); cascades with the project.
  robAssessments       RobAssessment[]
  // prompt46 #4 — RoB-local manual studies (added directly in the RoB engine).
  robManualStudies     RobManualStudy[]
  // prompt38 — server-backed per-module workflow state (additive back-relation).
  workflowModuleStates WorkflowModuleState[]

  // prompt50 WS5 — index for "Last Modified" sort + pagination on the owner's list.
  @@index([userId, lastActivityAt])
}

// roadmap 0.2 — relational backing for META·LAB per-project screening records.
// ADDITIVE + inert by default. Each row keeps indexed identity columns (for
// dedup/query at scale) PLUS a `data` column holding the exact mkRecord object,
// so rowsToProject(projectToRows(p)) deep-equals p (the JSON contract in
// data-model.md is preserved). All non-key columns are nullable → `prisma db
// push` stays additive-safe (no --accept-data-loss). Cascade-deletes with the
// parent Project. `mergedIntoId` is the soft-merge target reserved for 1.1.
model ReviewRecord {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordId     String // the in-document record.id (8-char uid) — stable across saves
  position     Int // preserves the records[] array order
  title        String?
  doi          String?
  pmid         String?
  decision     String?
  mergedIntoId String? // 1.1 soft-merge target; null = not merged
  data         String   @default("{}") // full mkRecord object, JSON-serialised
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, doi])
  @@index([projectId, pmid])
}

// roadmap 0.2 — relational backing for META·LAB per-project extracted studies.
// Same additive/inert pattern as ReviewRecord; `data` preserves the exact
// mkStudy object so the JSON contract round-trips.
model ReviewStudy {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studyId   String // the in-document study.id (8-char uid)
  position  Int // preserves the studies[] array order
  author    String?
  year      String?
  esType    String?
  data      String   @default("{}") // full mkStudy object, JSON-serialised
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ContactMessage {
  id           String               @id @default(uuid())
  email        String
  name         String?
  subject      String?
  message      String
  read         Boolean              @default(false) // legacy global read flag (kept for back-compat)
  archived     Boolean              @default(false)
  origin       String               @default("contact_form") // contact_form | staff (Ops-composed) | inbound_email
  replied      Boolean              @default(false) // prompt4 Task 4
  repliedAt    DateTime?
  // prompt49 — SHARED read state across all admins+mods. A message is unread
  // globally when readAt is null. Opening it sets readAt/readByUserId/readByName
  // for EVERYONE; any staff can mark it unread (clears these) for everyone. This
  // replaces the per-staff ContactMessageRead receipts as the source of truth
  // (the table is retained only for one-time backfill).
  readAt       DateTime?
  readByUserId String?
  readByName   String?
  createdAt    DateTime             @default(now())
  replies      ContactReply[]
  reads        ContactMessageRead[] // prompt5 Task 9 — per-staff read receipts (superseded by readAt; kept for backfill)
}

// Per-staff read receipt for an ops-console contact message (prompt5 Task 9).
// The unread badge is computed PER USER: a message is unread for a staff member
// when no ContactMessageRead row exists for (messageId, userId). This persists
// across logout/login and is independent per admin/mod.
model ContactMessageRead {
  id        String         @id @default(uuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime       @default(now())

  @@unique([messageId, userId])
}

// Email replies sent from the console to a contact message (prompt4 Task 4).
model ContactReply {
  id            String         @id @default(uuid())
  messageId     String
  message       ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  repliedById   String
  repliedByName String         @default("")
  toEmail       String
  subject       String         @default("")
  body          String
  status        String         @default("sent") // sent | failed | draft
  error         String         @default("")
  createdAt     DateTime       @default(now())
}

model SiteSetting {
  key       String   @id
  value     String // JSON-serialised value
  updatedAt DateTime @updatedAt
  updatedBy String? // admin userId who last changed this
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String // e.g. "UPDATE_SETTING", "SUSPEND_USER", "DELETE_MESSAGE"
  entityType String? // "User", "Project", "SiteSetting", "ContactMessage", etc.
  entityId   String?
  details    String? // JSON-serialised context (what changed, before/after summary)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model SecurityEvent {
  id        String   @id @default(uuid())
  type      String // "FAILED_LOGIN", "ADMIN_ACCESS_DENIED", "RATE_LIMITED"
  userId    String?
  email     String?
  ip        String?
  userAgent String?
  details   String? // JSON-serialised extra info
  createdAt DateTime @default(now())
}

// ─── META·SIFT Beta ──────────────────────────────────────────────────

// Per-user notification (prompt6 Task 1). The "Review Workspace" is the
// ScreenProject row — relatedScreenProjectId doubles as the workspaceId.
// No FK to User on purpose (matches SecurityEvent precedent; survives user deletion).
model Notification {
  id                      String    @id @default(uuid())
  userId                  String
  type                    String // PROJECT_INVITE | ROLE_CHANGED | ...
  title                   String
  message                 String    @default("")
  app                     String    @default("") // metalab | metasift | workspace
  relatedScreenProjectId  String? // = workspaceId (ScreenProject id)
  relatedMetaLabProjectId String?
  actorId                 String?
  actorName               String    @default("")
  actorEmail              String    @default("")
  role                    String    @default("") // role/preset granted, for invite notifications
  readAt                  DateTime?
  dismissedAt             DateTime?
  clickedAt               DateTime? // prompt9 — set when the user opens (clicks) the notification
  createdAt               DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Successful/failed login events for ops unique-login metrics (prompt6 Task 9).
// Kept separate from SecurityEvent so high-volume successes don't pollute forensics.
model LoginEvent {
  id        String   @id @default(uuid())
  userId    String
  email     String   @default("")
  ip        String   @default("")
  userAgent String   @default("")
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

// Project progressStatus change history (prompt6 Task 12).
// "Done today" = COUNT(DISTINCT projectId) WHERE status='done' AND createdAt >= startOfDay.
model ScreenProjectStatusEvent {
  id             String   @id @default(uuid())
  projectId      String
  status         String
  previousStatus String   @default("")
  changedById    String   @default("")
  changedByName  String   @default("")
  createdAt      DateTime @default(now())

  @@index([status, createdAt])
  @@index([projectId, createdAt])
}

model ScreenProject {
  id                         String    @id @default(uuid())
  ownerId                    String
  owner                      User      @relation("UserScreenProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  linkedMetaLabProjectId     String?
  title                      String
  description                String    @default("")
  reviewQuestion             String    @default("")
  stage                      String    @default("title_abstract")
  blindMode                  Boolean   @default(false)
  // prompt19 — per-project minimum independent title/abstract reviewer decisions
  // required before a record may advance to Full Text. Owner/leader editable in
  // Project Settings (default 2 = research standard). Additive int → db-push safe.
  requiredScreeningReviewers Int       @default(2)
  // ── upgrade additions ──────────────────────────────────────────────
  progressStatus             String    @default("not_started") // not_started | in_progress | done (leader-editable)
  archived                   Boolean   @default(false) // admin lifecycle
  disabled                   Boolean   @default(false) // admin per-project disable
  inclusionKeywords          String    @default("[]") // JSON string[] — green highlight terms
  exclusionKeywords          String    @default("[]") // JSON string[] — red highlight terms
  studyTypeFilter            String    @default("[]") // JSON string[]
  picoSnapshot               String    @default("{}") // cached PICO/criteria (from linked META·LAB project or standalone)
  chatRestricted             Boolean   @default(false) // when true, only members with canChat may post
  aiSettings                 String    @default("{}") // per-project AI screening policy (JSON: enabled, policy, blindFromAi, includeThreshold) — flag aiScreening
  deletedAt                  DateTime? // prompt9 — soft delete (owner/admin)
  deletedSource              String? // prompt9 — 'owner' | 'admin'
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  records          ScreenRecord[]
  labels           ScreenLabel[]
  exclusionReasons ScreenExclusionReason[]
  duplicateGroups  ScreenDuplicateGroup[]
  conflicts        ScreenConflict[]
  importBatches    ScreenImportBatch[]
  importJobs       ScreenImportJob[]
  members          ScreenProjectMember[]
  chatMessages     ScreenChatMessage[]
  auditLogs        ScreenAuditLog[]

  @@index([linkedMetaLabProjectId])
}

model ScreenRecord {
  id                         String                @id @default(uuid())
  projectId                  String
  project                    ScreenProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  importBatchId              String?
  importBatch                ScreenImportBatch?    @relation(fields: [importBatchId], references: [id])
  duplicateGroupId           String?
  duplicateGroup             ScreenDuplicateGroup? @relation(fields: [duplicateGroupId], references: [id])
  isPrimary                  Boolean               @default(false)
  isDuplicate                Boolean               @default(false)
  title                      String                @default("")
  authors                    String                @default("")
  year                       String                @default("")
  journal                    String                @default("")
  doi                        String                @default("")
  pmid                       String                @default("")
  abstract                   String                @default("")
  keywords                   String                @default("")
  sourceDb                   String                @default("")
  rawData                    String                @default("{}")
  // ── upgrade additions: two-stage workflow ──────────────────────────
  currentStage               String                @default("title_abstract") // title_abstract | full_text
  finalStatus                String                @default("") // "" | accepted | rejected
  promotedAt                 DateTime? // when it reached quorum and moved to full_text
  promotedVia                String                @default("") // "" | quorum | conflict_resolution (how it reached 2nd review)
  acceptedAt                 DateTime? // when accepted in second review (sent to extraction)
  rejectedReason             String                @default("")
  // ── META·LAB Data Extraction handoff state (prompt2 Task 4/5) ───────
  handoffStatus              String                @default("") // "" | pending | sent | failed | already_exists
  handoffAt                  DateTime?
  handoffStudyId             String                @default("") // id of the created META·LAB study (for idempotent re-sync)
  handoffError               String                @default("")
  // prompt21 — when a Final Review decision is REVERTED out of Data Extraction, the
  // removed META·LAB study (incl. any extracted data) is snapshotted here instead of
  // being destroyed, so a later re-accept can RESTORE it rather than start blank.
  // Nullable → `prisma db push` stays additive-safe.
  revertedExtractionSnapshot String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  decisions      ScreenDecision[]
  conflicts      ScreenConflict[]
  pdfAttachments ScreenPdfAttachment[]
  openStates     ScreenRecordOpenState[]

  // 62.md — every project-scoped read (records list, export, AI input load) filters by
  // projectId; without this index those are full-table scans that add real latency before
  // any CPU work even starts on a large project. Additive/safe for `prisma db push`.
  @@index([projectId])
}

model ScreenDecision {
  id              String       @id @default(uuid())
  recordId        String
  record          ScreenRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  projectId       String
  reviewerId      String
  reviewerName    String       @default("") // denormalised for blind-mode-safe display joins
  stage           String       @default("title_abstract") // which review stage this decision belongs to
  decision        String       @default("undecided")
  exclusionReason String       @default("")
  notes           String       @default("")
  rating          Int?
  labels          String       @default("[]")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([recordId, reviewerId, stage])
  // 62.md — export + AI input load fetch all decisions for a project; the unique key only
  // indexes recordId (the join side), not projectId (the filter side). Additive/safe.
  @@index([projectId])
}

