model ScreenImportBatch {
  id             String        @id @default(uuid())
  projectId      String
  project        ScreenProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename       String        @default("")
  format         String        @default("")
  recordCount    Int           @default(0) // records actually inserted (post import-time dedup)
  // 58.md §7 — PRISMA transparency: record the import-time dedup accounting so PRISMA
  // can show total-identified (before dedup) and duplicates-removed for EVERY source
  // (file + Pecan Search), not just post-import duplicate detection. Additive +
  // defaulted → `prisma db push` stays safe; legacy rows read 0 (documented gap).
  preDedupCount  Int           @default(0) // total parsed records offered to this import
  duplicateCount Int           @default(0) // skipped as duplicates AT import time
  rejectedCount  Int           @default(0) // skipped as unusable (no title/doi/pmid)
  source         String        @default("file") // file | pecan-search | api
  // ── import fingerprinting (prompt6 Task 19; nullable so legacy rows migrate clean) ──
  fileHash       String? // sha256 of line-ending-normalized content
  fileSize       Int?
  importedById   String?
  importedByName String        @default("")
  parser         String        @default("")
  createdAt      DateTime      @default(now())

  records ScreenRecord[]

  @@index([projectId, fileHash])
}

// prompt50 WS2 — durable, observable, retryable screening import job. The source
// content is persisted here (so the browser need NOT keep the dialog open and the
// job survives a request end / worker restart); an in-process worker parses,
// dedupes, and bulk-inserts in batches, writing progress back to this row. The
// source content is cleared once the job reaches a terminal state to reclaim
// space. Idempotent by (projectId, fileHash). All additive / defaulted → `prisma
// db push` stays safe.
model ScreenImportJob {
  id               String        @id @default(uuid())
  projectId        String
  project          ScreenProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById      String
  createdByName    String        @default("")
  // queued | processing | completed | completed_with_warnings | failed
  status           String        @default("queued")
  // queued | validating | detecting | parsing | deduplicating | saving | finalizing | done | failed
  stage            String        @default("queued")
  filename         String        @default("")
  format           String        @default("") // caller's hint (auto = content-detected)
  detectedFormat   String        @default("") // what the parser actually used
  fileHash         String?
  fileSize         Int           @default(0)
  content          String        @default("") // source text; cleared on terminal state
  force            Boolean       @default(false)
  totalRecords     Int           @default(0) // parsed record count
  processedRecords Int           @default(0) // deduped + considered so far
  importedRecords  Int           @default(0)
  duplicateRecords Int           @default(0)
  rejectedRecords  Int           @default(0)
  warningCount     Int           @default(0)
  errorReport      String        @default("[]") // JSON [{ index, title, reason }] for rejects
  error            String        @default("") // fatal error message (status=failed)
  // Number of times this job has been claimed/started. Incremented on every claim
  // so the boot recovery can cap retries of a job that crashes mid-import (poison
  // pill) instead of re-queuing it forever. See server/utils/jobRetry.js.
  attempts         Int           @default(0)
  batchId          String? // linked ScreenImportBatch once records are saved
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([projectId, status])
  @@index([status, createdAt])
  @@index([projectId, fileHash])
}

// ─── META·SIFT Beta — collaboration upgrade ──────────────────────────

model ScreenProjectMember {
  id                  String        @id @default(uuid())
  projectId           String
  project             ScreenProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId              String? // null for pending invites (user not yet registered)
  user                User?         @relation("UserScreenMemberships", fields: [userId], references: [id], onDelete: Cascade)
  name                String        @default("")
  email               String        @default("")
  role                String        @default("reviewer") // owner | leader | reviewer | viewer
  status              String        @default("active") // active | inactive | pending
  // ── META·SIFT permissions (existing) ───────────────────────────────
  canScreen           Boolean       @default(true)
  canChat             Boolean       @default(true)
  canResolveConflicts Boolean       @default(false)
  // ── Shared Review Workspace permissions (prompt4 Task 9; additive) ──
  permissionPreset    String        @default("reviewer") // owner|leader|reviewer|data_extractor|viewer|readonly_*
  // META·SIFT module
  canViewMetaSift     Boolean       @default(true)
  canSecondReview     Boolean       @default(true)
  canManageDuplicates Boolean       @default(false)
  canImportRecords    Boolean       @default(false)
  canExportRecords    Boolean       @default(false)
  readOnlyMetaSift    Boolean       @default(false)
  // META·LAB module
  canViewMetaLab      Boolean       @default(true)
  canEditMetaLab      Boolean       @default(false)
  canManageExtraction Boolean       @default(false)
  canRunAnalysis      Boolean       @default(false)
  canExport           Boolean       @default(false)
  canAssessRiskOfBias Boolean       @default(false) // prompt31 Part 4 — edit RoB assessments
  readOnlyMetaLab     Boolean       @default(false)
  // Global
  canManageMembers    Boolean       @default(false)
  canManageSettings   Boolean       @default(false)
  // ── Invite lifecycle (prompt9 — token ceremony atop the pending row) ──
  invitedByUserId     String? // who created the invite (fixes "A project manager" UX gap)
  // Plain index, NOT @unique: a unique constraint forces `prisma db push` (the VPS deploy path)
  // to demand --accept-data-loss, which the deploy script does not pass. Uniqueness is already
  // guaranteed by 256-bit random token generation + single-use nulling on accept; the index keeps
  // the hash lookup fast. Looked up via findFirst (findUnique requires a @unique field).
  inviteTokenHash     String? // SHA-256 hex of the invite token; plaintext never stored
  inviteExpiresAt     DateTime? // invite validity window (default now + inviteExpiryDays)
  inviteAcceptedAt    DateTime? // when the invite was accepted/claimed (single-use marker)
  joinedAt            DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([projectId, email])
  @@index([inviteTokenHash])
}

