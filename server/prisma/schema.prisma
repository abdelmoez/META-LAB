// bare scope keys (records may be soft-deleted). Pairs stored in canonical order A<B.
model ScreenDuplicateLabel {
  id            String   @id @default(uuid())
  projectId     String
  recordIdA     String
  recordIdB     String
  label         String // duplicate | not_duplicate | related | uncertain
  predictedType String   @default("") // classifier verdict at label time (classifyPair)
  score         Int      @default(0)
  reason        String   @default("")
  modelVersion  String   @default("")
  reviewerId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, recordIdA, recordIdB])
  @@index([projectId])
}

model ScreenConflict {
  id                String        @id @default(uuid())
  projectId         String
  project           ScreenProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordId          String
  record            ScreenRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  reviewerDecisions String        @default("{}")
  finalDecision     String        @default("")
  resolvedBy        String        @default("")
  resolvedAt        DateTime?
  notes             String        @default("")
