// Best-effort product-usage events for ops metrics (prompt9).
// No FKs on purpose (SecurityEvent/Notification precedent) — audit-survival:
// rows must outlive the users/projects they describe.
model UsageEvent {
  id               String   @id @default(uuid())
  type             String // EXPORT | EMAIL_SENT | EMAIL_FAILED | MEMBER_LEFT | PROJECT_DELETED | INVITE_CREATED | INVITE_ACCEPTED | INVITE_REVOKED | NOTIFICATION_CLICKED
  userId           String?
