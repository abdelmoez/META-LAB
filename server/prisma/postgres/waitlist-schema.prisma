// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../generated/postgres-waitlist-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_WAITLIST_DATABASE_URL")
  directUrl = env("POSTGRES_WAITLIST_DIRECT_DATABASE_URL")
}

model BetaWaitlistApplicant {
  id              String @id @default(uuid())
  // email keeps the address as typed (display); normalizedEmail (trimmed +
  // lowercased) is the case-insensitive UNIQUE dedupe key.
  email           String
  normalizedEmail String @unique

  // 54.md Part 3 — names are now OPTIONAL (doc: "make all fields optional except
  // Country"; the minimal required set is email + country + consent). Existing
  // rows keep their NOT-NULL values; relaxing to nullable is a non-destructive
  // `db push` (DROP NOT NULL), so legacy records stay valid + readable.
  firstName        String?
  lastName         String?
  institutionName  String? // doc: institution NAME is sensitive at sign-up → optional
  institutionRorId String? // optional normalized institution identifier (ROR)

  role       String? // doc Q1 — now optional
  customRole String? // only when role == "Other"

  countryCode String // REQUIRED (doc Q3 — GDPR)
  countryName String

  // 54.md Part 3 — new questionnaire fields from WhatToCollectFromUsers.docx.
  // All nullable → additive `db push`; old applicants simply have null answers.
  primaryField     String? // doc Q2 — Medicine / Nursing / Pharmacy / …
  institutionType  String? // doc Q5 — University / Hospital / CRO / …
  covidenceLicense String? // doc Q4 — Yes / No / Not sure (competitive signal)
  priorReviewCount String? // doc Q6 — first / 1–2 / 3–5 / more than 5
  lastReviewTool   String? // doc Q7 — first / Rayyan / Covidence / Excel / …

  researchExperienceLevel String?
  annualReviewVolume      String?
  workingStyle            String? // "Individual" | "Research team"
  teamSize                String?

  areasOfInterest String  @default("[]") // JSON-encoded array of interest strings
  primaryUse      String? // now optional (doc: all optional except Country)
  referralSource  String?
  referralOther   String?
  message         String?

  // Consent — explicit, never pre-checked. consentVersion records WHICH copy the
  // applicant agreed to; consentAt is the server timestamp of agreement.
  //
  // 54.md Part 3 / WhatToCollectFromUsers.docx legal requirement — TWO consent
  // layers kept separate: (1) `consent` is OPERATIONAL (required — agree to be
  // contacted about the beta); (2) `researchConsent` is a SEPARATE, OPTIONAL
  // opt-in to aggregated/anonymized research-insights use (never required, never
  // pre-checked). Defaulting researchConsent=false keeps `db push` additive.
  consent           Boolean   @default(false)
  consentVersion    String?
  consentAt         DateTime?
  researchConsent   Boolean   @default(false)
  researchConsentAt DateTime?

  status           String @default("WAITLISTED") // see WAITLIST_STATUSES
  submissionSource String @default("public_web")

  // Confirmation-email delivery tracking. lastConfirmationEmailError stores a SAFE
  // short reason only — never SMTP secrets or stack traces.
  confirmationEmailStatus    String    @default("pending") // pending|queued|sent|failed|skipped
  confirmationEmailSentAt    DateTime?
  lastConfirmationEmailError String?
  confirmationEmailAttempts  Int       @default(0)
  lastConfirmationAttemptAt  DateTime?

  // Administrative — never shown to the applicant.
  internalNotes String?

  // Lifecycle timestamps (optional; set when status advances).
  invitedAt  DateTime?
  acceptedAt DateTime?
  removedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusEvents BetaWaitlistStatusEvent[]

  @@index([status])
  @@index([createdAt])
  @@index([countryCode])
  @@index([role])
  @@index([confirmationEmailStatus])
  // 54.md — Ops filtering on the new high-signal questionnaire fields.
  @@index([institutionType])
  @@index([primaryField])
  @@index([covidenceLicense])
}

// Append-only status history for the Ops detail view + audit trail.
model BetaWaitlistStatusEvent {
  id          String                @id @default(uuid())
  applicantId String
  applicant   BetaWaitlistApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  // Opaque admin userId from the MAIN db (no cross-database FK on purpose).
  changedBy   String?
  note        String?
  createdAt   DateTime              @default(now())

  @@index([applicantId])
}
