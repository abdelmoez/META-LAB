# ──────────────────────────────────────────────────────────────────────────────
# server/.env.example — META·LAB API server environment
# Copy to server/.env and fill in real values. NEVER commit the real .env.
# Loaded by server/load-env.js (resolved relative to this file) before any
# Prisma/JWT/auth module initialises.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Prisma) ──────────────────────────────────────────────────────────
# Dev: SQLite file (relative to server/prisma/). Prod: switch the Prisma provider
# to "postgresql" (see docs/manager/deployment-readiness.md) and use a managed
# connection string, e.g. postgresql://user:pass@host:5432/metalab?schema=public
DATABASE_URL="file:./dev.db"

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Long random secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-hex-string"

# ── Runtime ────────────────────────────────────────────────────────────────────
# "development" relaxes rate limits and disables Secure cookies; use "production"
# when deployed (enables Secure cookies + strict auth rate limiting).
NODE_ENV="development"
# Port the Express API listens on.
PORT=3001

# ── Admin seeding (server/auth/seedAdmins.js) ──────────────────────────────────
# These two accounts are created/ensured on boot with ADMIN_SEED_PASSWORD.
ADMIN_EMAIL_1="admin@example.com"
ADMIN_EMAIL_2="ops@example.com"
# Initial password for the seeded admin accounts. Rotate after first login.
ADMIN_SEED_PASSWORD="change-me-strong-password"

# ── CORS / app base URL ────────────────────────────────────────────────────────
# Allowed browser origin for credentialed requests. In production set this to the
# deployed frontend origin (https://app.example.com). server/index.js reads
# CORS_ORIGIN first, then APP_BASE_URL, then falls back to http://localhost:3000.
CORS_ORIGIN="http://localhost:3000"
# Canonical public base URL of the app. Used as the CORS fallback and by email
# links. Set to the production HTTPS origin when deployed.
APP_BASE_URL="http://localhost:3000"

# ── Email / SMTP (consumed by the contact/notification layer) ──────────────────
# Provider selector for the mail service (e.g. "smtp", "console", "none").
EMAIL_PROVIDER="console"
# SMTP transport settings (used when EMAIL_PROVIDER=smtp).
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="apikey-or-username"
SMTP_PASS="change-me-smtp-password"
# Default From: address for outbound mail.
EMAIL_FROM="META·LAB <no-reply@example.com>"

# ── Build / versioning (optional; read by server/version.js) ───────────────────
# Set by CI so /api/version reports the exact build. If unset, the server falls
# back to `git rev-parse --short HEAD` for the commit and module-load time for
# the build date.
GIT_COMMIT=""
BUILD_DATE=""
