# ──────────────────────────────────────────────────────────────────────────────
# server/.env.example — PecanRev API server environment
# Copy to server/.env and fill in real values. NEVER commit the real .env.
# Loaded by server/load-env.js (resolved relative to this file) before any
# Prisma/JWT/auth module initialises.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Prisma) ──────────────────────────────────────────────────────────
# Dev: SQLite file (relative to server/prisma/). Prod: switch the Prisma provider
# to "postgresql" (see docs/manager/deployment-readiness.md) and use a managed
# connection string, e.g. postgresql://user:pass@host:5432/metalab?schema=public
DATABASE_URL="file:./dev.db"

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Long random secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-hex-string"

# ── Runtime ────────────────────────────────────────────────────────────────────
# "development" relaxes rate limits and disables Secure cookies; use "production"
# when deployed (enables Secure cookies + strict auth rate limiting).
NODE_ENV="development"
# Port the Express API listens on.
PORT=3001

# ── Reverse-proxy / client IP (registration country detection) ─────────────────
# Express derives the real client IP (req.ip) from X-Forwarded-For ONLY when
# 'trust proxy' is configured. Default (unset) trusts loopback/link-local/unique-
# local upstreams — correct when nginx talks to Node over 127.0.0.1 / a unix
# socket AND sets `proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;`.
# Override: "true" | "false" | a hop count (e.g. "1") | a CSV of subnets.
# Country detection (server/utils/geo.js) needs a correct public req.ip; it uses
# the offline geoip-lite DB (an optionalDependency) and/or a proxy country header
# (CF-IPCountry, x-vercel-ip-country) when present. Wrong trust-proxy ⇒ private
# req.ip ⇒ country saved as "Unknown".
TRUST_PROXY=

# ── Admin seeding (server/auth/seedAdmins.js) ──────────────────────────────────
# These two accounts are created/ensured on boot with ADMIN_SEED_PASSWORD.
ADMIN_EMAIL_1="admin@example.com"
ADMIN_EMAIL_2="ops@example.com"
# Initial password for the seeded admin accounts. Rotate after first login.
ADMIN_SEED_PASSWORD="change-me-strong-password"

# ── CORS / app base URL ────────────────────────────────────────────────────────
# Allowed browser origin for credentialed requests. In production set this to the
# deployed frontend origin (https://pecanrev.com). server/index.js reads
# CORS_ORIGIN first, then APP_BASE_URL, then falls back to http://localhost:3000.
CORS_ORIGIN="http://localhost:3000"
# Canonical public base URL of the app. Used as the CORS fallback and to build
# invite + password-reset links in outbound email (e.g. ${APP_BASE_URL}/reset?token=…).
# In production this MUST be set to https://pecanrev.com (it drives both the
# email links and CORS). If unset, email links fall back to the request origin.
APP_BASE_URL="http://localhost:3000"

# ── Email / SMTP (contact replies, invites, password reset) ────────────────────
# Email is OPTIONAL. Sending is enabled ONLY when BOTH SMTP_HOST and EMAIL_FROM
# are set (isEmailConfigured()). When unset, the app stays fully usable: contact
# replies save as drafts and invite/reset links are shown to the operator instead
# — nothing 500s. NEVER commit real secrets; set these in the deploy environment.
#
#   SMTP_PORT 587 → STARTTLS (default).  SMTP_PORT 465 → implicit TLS.
#   SMTP_USER / SMTP_PASS are optional (omit for unauthenticated relays).
#   Gmail app passwords are dev/low-volume only; prefer a transactional provider
#   (Resend / SendGrid / Postmark / SES) in production. See server/docs/email-setup.md.
#
# EMAIL_PROVIDER is an informational label shown in the ops console only.
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Lifetime of a password-reset token link, in minutes (default 60).
PASSWORD_RESET_TTL_MINUTES=60

# ── Build / versioning (optional; read by server/version.js) ───────────────────
# Set by CI so /api/version reports the exact build. If unset, the server falls
# back to `git rev-parse --short HEAD` for the commit and module-load time for
# the build date.
GIT_COMMIT=""
BUILD_DATE=""

# ── AI Screening Intelligence Engine (screeningEngin.md) ───────────────────────
# The engine is OFF by default (feature flag `aiScreening` in Ops › Feature Flags).
# Its core (TF-IDF + active-learning logistic regression) is fully in-process and
# DETERMINISTIC — it needs NO env vars and makes NO external calls. Operational
# policy (enabled / provider / quotas / thresholds) is configured at runtime in
# Ops › Feature Flags › AI Screening (stored in the aiScreeningSettings SiteSetting),
# NOT via env, so no redeploy is needed to tune it.
#
# The variables below are OPTIONAL and only relevant if you set the embedding
# provider to `hosted` to add a semantic layer on top of the deterministic engine
# (the documented "next phase" hosted-embedding extension point in
# server/services/screeningAiService.js). With them unset, `hosted` gracefully
# falls back to the in-process lexical engine. Never commit real secret values.
# AI_EMBEDDING_PROVIDER=lexical            # lexical | hashing | hosted (Ops setting usually wins)
# AI_EMBEDDING_ENDPOINT=                   # OpenAI-compatible /v1/embeddings URL for `hosted`
# AI_EMBEDDING_MODEL=                      # e.g. text-embedding-3-small
# AI_EMBEDDING_API_KEY=                    # secret — server-side only, never exposed to the client
