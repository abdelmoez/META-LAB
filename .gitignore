# dependencies
node_modules/
server/node_modules/

# build output
dist/

# environment — NEVER commit real secrets
.env
server/.env
*.env.local

# database migrations state (keep schema, not lock)
server/prisma/migrations/

# local SQLite databases — NEVER commit (contain user emails, password hashes,
# contact messages). Found tracked during the prompt7 security review.
server/prisma/*.db
server/prisma/*.db-journal
server/prisma/*.db.bak*
*.sqlite
*.sqlite3

# runtime data (JSON file store — superseded by Postgres)
server/data/*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
*.suo
*.user

# test artifacts
coverage/
.nyc_output/

# META·SIFT uploaded PDFs (local file storage — see docs/manager/project-data-isolation.md)
server/storage/

# local server run logs
server-test.log
server-test.err.log
server-stdout.log
server-stderr.log
*.test.log
bash.exe.stackdump

# Build-time generated version metadata (npm run version:gen) — derived, not committed
server/version.json

# graphify knowledge graph (generated, rebuild with /graphify)
graphify-out/
