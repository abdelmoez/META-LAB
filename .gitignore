# dependencies
node_modules/
server/node_modules/

# build output
dist/

# environment — NEVER commit real secrets
.env
server/.env
*.env.local

# Stitch MCP (design source) — a local Claude MCP config can carry the
# X-Goog-Api-Key header (STITCH_API_KEY). NEVER commit it. The MCP is added at
# USER scope via `claude mcp add` (see docs/manager/54-stitch-waitlist-engine-versions.md
# and .env.example); a repo-level .mcp.json must stay secret-free.
.mcp.json
.mcp.local.json

# Prisma migrations ARE committed (full history + migration_lock.toml) so
# `npx prisma migrate deploy` works from a clean clone. Fixed 2026-06-12 —
# they were wrongly ignored before, contradicting deployment-readiness.md.

# local SQLite databases — NEVER commit (contain user emails, password hashes,
# contact messages). Found tracked during the prompt7 security review.
server/prisma/*.db
server/prisma/*.db-journal
server/prisma/*.db.bak*
*.sqlite
*.sqlite3

# prompt48 — Beta Waitlist: the strictly-separate SQLite DB (applicant PII) and
# its dedicated generated Prisma client (large, platform-specific binaries —
# regenerated via `npx prisma generate --schema=prisma/waitlist/schema.prisma`,
# same convention as the main client which is also never committed).
server/prisma/waitlist/*.db
server/prisma/waitlist/*.db-journal
server/prisma/generated/

# runtime data (JSON file store — superseded by Postgres)
server/data/*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
*.suo
*.user

# test artifacts
coverage/
.nyc_output/

# META·SIFT uploaded PDFs (local file storage — see docs/manager/project-data-isolation.md)
server/storage/

# local server run logs
server-test.log
server-test.err.log
server-stdout.log
server-stderr.log
*.test.log
bash.exe.stackdump

# Build-time generated version metadata (npm run version:gen) — derived, not committed
server/version.json

# graphify knowledge graph (generated, rebuild with /graphify)
graphify-out/

# design-sync (claude.ai/design) — staged scripts, build output, machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Pecan search diagnostic harness outputs (regenerated on demand)
scripts/pecan-harness-report.json
scripts/pecan-harness-report.md
scripts/pecan-harness-live.log

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
e2e/.auth/
playwright-report/
test-results/

# Playwright E2E discovery run logs (artifacts, not source)
e2e/.discovery/*.log
e2e/.discovery/server.*
