# ─── Database ───────────────────────────────────────────────────────────────────
# Local PostgreSQL via Docker Compose (docker compose up -d)
DATABASE_URL="postgresql://metalab:metalab_local@localhost:5432/metalab_dev"

# ─── Auth ───────────────────────────────────────────────────────────────────────
# JWT signing secret — generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit a real value here.
JWT_SECRET="REPLACE_ME_WITH_64_CHAR_HEX_STRING"

# ─── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
