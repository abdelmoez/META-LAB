# ─── Database ────────────────────────────────────────────────────────────────────
# SQLite — no external service needed for local development
DATABASE_URL="file:./dev.db"

# ─── Auth ────────────────────────────────────────────────────────────────────────
# JWT signing secret — generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit a real value here.
JWT_SECRET="REPLACE_ME_WITH_64_CHAR_HEX_STRING"

# ─── Server ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# ─── Admin Users (seed script) ───────────────────────────────────────────────────
# These two addresses become the only admin users.
# Run `node server/scripts/seed-admins.js` after setting these values.
# If either email already exists as a normal user it will be promoted to admin.
# NEVER commit real values here — fill them in your local server/.env file.
ADMIN_EMAIL_1="admin1@example.com"
ADMIN_EMAIL_2="admin2@example.com"

# Shared initial password for both admin accounts (change immediately after first login).
# Must be at least 12 characters. NEVER commit a real value.
ADMIN_SEED_PASSWORD="REPLACE_ME_STRONG_PASSWORD_12_CHARS"
