{
  "name": "meta-lab",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "lint": "eslint .",
    "server": "node server/index.js",
    "version:gen": "node scripts/generate-version.js",
    "stage:ocr": "node scripts/stage-ocr-assets.mjs",
    "build": "node scripts/stage-ocr-assets.mjs && npm run version:gen && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration tests/screening/integration --pool=forks --poolOptions.forks.singleFork=true",
    "test:ci": "vitest run tests/unit tests/screening/unit",
    "test:search-builder-intelligence": "node scripts/search-builder-benchmark.mjs",
    "test:screening-benchmark": "node scripts/screening-benchmark.mjs",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "loadtest:beta": "node scripts/loadtest/beta-load.mjs",
    "review:legal": "node scripts/review-legal.js",
    "review:ops-impact": "node scripts/review-ops-impact.js",
    "engine-version:check": "node scripts/engine-version.mjs check",
    "engine-version:bump": "node scripts/engine-version.mjs bump",
    "engine-registry:seed": "node server/scripts/seed-engine-registry.js",
    "marketing:seed": "node scripts/seed-marketing-demo.mjs",
    "marketing:seed:remove": "node scripts/seed-marketing-demo.mjs --remove",
    "marketing:screenshots": "node scripts/capture-marketing-screenshots.mjs",
    "marketing:curate": "node scripts/curate-marketing-screenshots.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ci": "playwright test --reporter=html,list",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "docx": "^9.7.1",
    "framer-motion": "^12.40.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jszip": "^3.10.1",
    "playwright": "^1.49.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
