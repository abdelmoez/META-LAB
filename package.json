{
  "name": "meta-lab",
  "version": "3.39.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/index.js",
    "version:gen": "node scripts/generate-version.js",
    "build": "npm run version:gen && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ci": "vitest run tests/unit tests/screening/unit",
    "review:legal": "node scripts/review-legal.js",
    "review:ops-impact": "node scripts/review-ops-impact.js",
    "marketing:seed": "node scripts/seed-marketing-demo.mjs",
    "marketing:seed:remove": "node scripts/seed-marketing-demo.mjs --remove",
    "marketing:screenshots": "node scripts/capture-marketing-screenshots.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "playwright": "^1.49.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
